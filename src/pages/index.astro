---
import Layout from '../layouts/Layout.astro';
---
<Layout title="ICM Factory Direct: Custom Sportswear Manufacturer in Vietnam">

  <!-- HERO SECTION -->
  <section class="relative w-full min-h-[85vh] flex items-center justify-center text-center overflow-hidden bg-navy-900">
    <div class="absolute inset-0 bg-gradient-to-br from-navy-900 via-navy-800 to-navy-700"></div>
    <div class="relative z-10 max-w-5xl mx-auto px-4 py-24">
      <p class="text-gold-400 uppercase tracking-[0.3em] text-sm font-semibold mb-6">Your Partner in Excellence</p>
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-extrabold text-white tracking-tight mb-8 leading-tight">
        Custom Sportswear Solutions<br class="hidden md:block" /> for Brand Owners
      </h1>
      <p class="text-lg md:text-xl text-gray-300 max-w-3xl mx-auto mb-12 leading-relaxed">
        Unlock the potential of your brand with ICM Factory Direct's unwavering commitment to innovation, quality, and collaboration.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/documents/ICM-eBrochure-2025.pdf" target="_blank" class="bg-gold-400 text-navy-900 hover:bg-gold-500 px-8 py-3.5 rounded-full font-bold text-lg transition-all transform hover:-translate-y-1 shadow-lg">
          VIEW MORE
        </a>
        <a href="#" class="bg-transparent border-2 border-white/30 hover:border-white text-white px-8 py-3.5 rounded-full font-bold text-lg transition-all">
          PLAY VIDEO
        </a>
      </div>
    </div>
  </section>

  <!-- CORE VALUES -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-3 gap-8">
        <div class="text-center p-8 rounded-2xl bg-gray-50 hover:shadow-lg transition-shadow">
          <div class="w-16 h-16 mx-auto bg-gold-400/10 text-gold-500 rounded-full flex items-center justify-center mb-6">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Excellent Material</h3>
          <p class="text-gray-600">We source and utilize premium materials, ensuring our sportswear delivers unmatched comfort, durability, and performance.</p>
        </div>
        <div class="text-center p-8 rounded-2xl bg-gray-50 hover:shadow-lg transition-shadow">
          <div class="w-16 h-16 mx-auto bg-blue-50 text-blue-600 rounded-full flex items-center justify-center mb-6">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Quality Product</h3>
          <p class="text-gray-600">Our meticulous attention to detail and stringent quality control processes ensure that every product meets the highest standards of excellence.</p>
        </div>
        <div class="text-center p-8 rounded-2xl bg-gray-50 hover:shadow-lg transition-shadow">
          <div class="w-16 h-16 mx-auto bg-green-50 text-green-600 rounded-full flex items-center justify-center mb-6">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Trusted by Clients</h3>
          <p class="text-gray-600">20 years track record of delivering exceptional sportswear solutions has earned us the trust and loyalty of numerous satisfied clients worldwide.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ABOUT ICM -->
  <section id="why-icm" class="py-24 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Empowering Performance, Inspiring Success.</h2>
        <p class="text-xl text-gray-600">At ICM Factory Direct, we are passionate about empowering athletes and brands through our exceptional sportswear solutions.</p>
      </div>
      <div class="grid md:grid-cols-2 gap-12">
        <div>
          <h3 class="text-2xl font-bold text-gray-900 mb-6">Our Vision</h3>
          <ul class="space-y-4">
            <li class="flex items-start gap-3"><span class="text-gold-400 mt-1">✦</span><span class="text-gray-700">Global leader in innovative sportswear solutions.</span></li>
            <li class="flex items-start gap-3"><span class="text-gold-400 mt-1">✦</span><span class="text-gray-700">Inspiring athletes and brands to excel.</span></li>
            <li class="flex items-start gap-3"><span class="text-gold-400 mt-1">✦</span><span class="text-gray-700">Redefining sportswear through design and sustainability.</span></li>
            <li class="flex items-start gap-3"><span class="text-gold-400 mt-1">✦</span><span class="text-gray-700">Promoting health, wellness, and the joy of sports.</span></li>
            <li class="flex items-start gap-3"><span class="text-gold-400 mt-1">✦</span><span class="text-gray-700">Creating a positive impact on lives and the environment.</span></li>
          </ul>
        </div>
        <div>
          <h3 class="text-2xl font-bold text-gray-900 mb-6">Our Mission</h3>
          <ul class="space-y-4">
            <li class="flex items-start gap-3"><span class="text-blue-500 mt-1">✦</span><span class="text-gray-700">Designing cutting-edge sportswear for performance.</span></li>
            <li class="flex items-start gap-3"><span class="text-blue-500 mt-1">✦</span><span class="text-gray-700">Collaborating for tailored brand solutions.</span></li>
            <li class="flex items-start gap-3"><span class="text-blue-500 mt-1">✦</span><span class="text-gray-700">Upholding craftsmanship and quality.</span></li>
            <li class="flex items-start gap-3"><span class="text-blue-500 mt-1">✦</span><span class="text-gray-700">Embracing sustainability in our practices.</span></li>
            <li class="flex items-start gap-3"><span class="text-blue-500 mt-1">✦</span><span class="text-gray-700">Providing exceptional customer service.</span></li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA BANNER -->
  <section class="py-20 bg-navy-900 text-white text-center">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-3xl md:text-4xl font-bold mb-6">Let's Make Your Sportswear That Sells Itself.</h2>
      <p class="text-lg text-gray-300 mb-10">Take your Sportswear Line to the next level. Discover the power of Tailor-Made Sportswear solutions. Ready to make your mark? Contact us today!</p>
      <a href="/contact-us/" class="bg-gold-400 text-navy-900 hover:bg-gold-500 px-10 py-4 rounded-full font-bold text-lg transition-all transform hover:-translate-y-1 shadow-lg inline-block">
        CONTACT US
      </a>
    </div>
  </section>

</Layout>
