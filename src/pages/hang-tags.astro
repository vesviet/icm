---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Custom Hang Tags | ICM Factory Direct">
  <section class="py-24 md:py-32 bg-navy-900 text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <p class="text-gold-400 font-bold uppercase tracking-[0.2em] text-sm mb-4">Retail Ready</p>
        <h1 class="text-4xl md:text-5xl font-extrabold mb-6">Custom Hang Tags & Woven Labels</h1>
        <p class="text-xl max-w-2xl mx-auto text-gray-300">
          The final touch that elevates your product from a garment to a brand experience.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-white/10 p-8 rounded-xl backdrop-blur-sm border border-white/20 hover:bg-white/20 transition-colors">
          <h3 class="text-2xl font-bold text-gold-400 mb-4">Hang Tags</h3>
          <p class="text-gray-300">Custom printed hang tags in any shape or size. Choose from various paper weights, finishes (matte, gloss, soft-touch), and string options (cotton, wax, plastic seal).</p>
        </div>
        <div class="bg-white/10 p-8 rounded-xl backdrop-blur-sm border border-white/20 hover:bg-white/20 transition-colors">
          <h3 class="text-2xl font-bold text-gold-400 mb-4">Woven Labels</h3>
          <p class="text-gray-300">Premium damask woven labels sewn into the neck or hem. Available in straight cut, center fold, or end fold for a classic, durable branding solution.</p>
        </div>
        <div class="bg-white/10 p-8 rounded-xl backdrop-blur-sm border border-white/20 hover:bg-white/20 transition-colors">
          <h3 class="text-2xl font-bold text-gold-400 mb-4">Heat Press Labels</h3>
          <p class="text-gray-300">Tagless neck labels applied via heat transfer. Perfect for activewear where comfort is paramount and woven labels might cause irritation.</p>
        </div>
      </div>
    </div>
  </section>
</Layout>
