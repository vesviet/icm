---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';

const fabrics = [
  { 
    title: 'SITIP Technical Textiles', 
    image: '/images/MG_9183.webp', 
    link: null 
  },
  { 
    title: 'SITIP Technical Textiles', 
    image: '/images/MG_9196.webp', 
    link: null 
  },
  { 
    title: 'SITIP Technical Textiles', 
    image: '/images/MG_9191.webp', 
    link: null 
  },
  { 
    title: 'High Performance', 
    image: '/images/High-Performance.jpg', 
    link: '/fabrics/high-performance-2/' 
  },
  { 
    title: 'SITIP Technical Textiles', 
    image: '/images/MG_9194.webp', 
    link: null 
  },
  { 
    title: '100% Cotton', 
    image: '/images/100-Cotton.jpg', 
    link: '/fabrics/100-cotton-2/' 
  },
  { 
    title: 'Polyester', 
    image: '/images/Polyester.jpg', 
    link: '/fabrics/polyester-2/' 
  },
  { 
    title: 'Trucker Mesh', 
    image: '/images/Trucker-Mesh.jpg', 
    link: '/fabrics/trucker-mesh-2/' 
  },
  { 
    title: 'Poly/Cotton', 
    image: '/images/Poly-Cotton.jpg', 
    link: '/fabrics/poly-cotton-2/' 
  },
  { 
    title: 'Polyester/Spandex', 
    image: '/images/Polyester-Spandex.jpg', 
    link: '/fabrics/polyester-spandex-2/' 
  },
  { 
    title: 'Polyester/Rayon', 
    image: '/images/Polyester-Rayon.jpg', 
    link: '/fabrics/polyester-rayon-2/' 
  },
  { 
    title: 'Wool/Acrylic', 
    image: '/images/Wool-Acrylic.jpg', 
    link: '/fabrics/wool-acrylic/' 
  }
];
---

<Layout title="High-Performance Fabrics by ICM Factory Direct">
  <PageHero
    title="Fabrics"
    breadcrumbs={[
      { label: "Home", href: "/" },
      { label: "Product Features", href: "#" },
      { label: "Fabrics" }
    ]}
    backgroundImage="/images/worker-in-textile-industry-sewing-FQEGPTY-1.jpg"
    overlayOpacity={0.6}
    overlayColor="#1D2F40"
  />

  <section class="py-[52.8px] bg-white">
    <div class="max-w-[1340px] w-full mx-auto px-[10px]">
      <div class="text-center mb-12">
        <h2 class="font-nav text-[19.2px] font-semibold tracking-[2.5px] text-[#A6587C] uppercase mb-3">Excellent Material</h2>
        <h3 class="font-heading text-[38px] md:text-[44px] font-semibold leading-[1.2] text-[#1D2F40]">ICM Factory Direct Sports Apparel Is Design To Fit Your Need</h3>
      </div>
      
      <p class="font-body text-[17.6px] leading-[1.5] text-[#757575] text-center max-w-[900px] mx-auto mb-12">
        We use a selection of high-performance fabrics specifically designed to enhance your athletic performance and comfort. Whether you're a professional athlete or an enthusiastic fitness enthusiast, we have the fabrics you need to excel in your chosen sport.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
        {fabrics.map(fabric => (
          <div class="group relative overflow-hidden rounded-[10px] border border-[#A6587C]">
            {fabric.link ? (
              <a href={fabric.link} class="block h-full w-full">
                <img src={fabric.image} alt={fabric.title} class="w-full h-[240px] object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                <div class="p-4 bg-[#1D2F40] absolute bottom-0 left-0 w-full">
                  <h4 class="font-heading text-[18px] font-medium leading-[1.2] text-white text-center">{fabric.title}</h4>
                  <span class="block text-center text-[#A6587C] text-[13px] font-semibold uppercase tracking-wider mt-2 group-hover:text-white transition-colors">VIEW ALL <span class="inline-block ml-1">→</span></span>
                </div>
              </a>
            ) : (
              <div class="h-full w-full">
                <img src={fabric.image} alt={fabric.title} class="w-full h-[240px] object-cover" loading="lazy" />
                <div class="p-6 bg-[#1D2F40] absolute bottom-0 left-0 w-full">
                  <h4 class="font-heading text-[20px] font-medium leading-[1.2] text-white text-center">{fabric.title}</h4>
                </div>
              </div>
            )}
          </div>
        ))}
      </div>
      
      <div class="text-center bg-[#F2F2F2] border border-[#A6587C] p-8 mt-12">
        <h3 class="font-heading text-[28px] font-semibold text-[#1D2F40] mb-4">ICM Factory Direct Sports Apparel Is Design To Fit Your Need</h3>
        <p class="font-body text-[17.6px] text-[#757575] max-w-4xl mx-auto mb-6">
          ICM Factory Direct specializes in small to mid-size orders, with MOQ's as low as 25 units per order. Our customers operate in the team sports uniform arena, events, corporate promotional apparel, and sports brands.
        </p>
        <a href="/contact-us/" class="inline-flex items-center justify-center bg-[#A6587C] hover:bg-[#7D405C] text-[#F4F4F4] font-nav text-[17.6px] font-semibold uppercase tracking-[1px] py-[14px] px-[30px] transition-colors">
          CONTACT US
        </a>
      </div>

    </div>
  </section>
</Layout>
