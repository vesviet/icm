---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Premium Fabrics & Materials | ICM Factory Direct">
  <!-- Hero Section -->
  <section class="relative pt-32 pb-24 bg-navy-900 overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img src="/images/fabrics/sitip-technical-textles-fabrics-1.webp" alt="Premium Fabrics" class="w-full h-full object-cover opacity-30" />
      <div class="absolute inset-0 bg-gradient-to-t from-navy-900 to-transparent"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center text-white">
      <p class="text-gold-400 font-bold uppercase tracking-[0.2em] text-sm mb-4">Innovation Woven In</p>
      <h1 class="text-5xl md:text-6xl font-extrabold tracking-tight mb-6">Premium Fabrics</h1>
      <p class="text-xl max-w-3xl mx-auto text-gray-300 font-light leading-relaxed">
        Experience the pinnacle of performance with our Italian-engineered textiles. Designed for breathability, durability, and absolute comfort.
      </p>
    </div>
  </section>

  <!-- Sitip Italy Section -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div class="order-2 md:order-1">
          <div class="grid grid-cols-2 gap-4">
            <img src="/images/fabrics/sitip-technical-textles-fabrics-1.webp" alt="Sitip Fabric Detail" class="rounded-xl shadow-lg w-full h-64 object-cover transform hover:scale-105 transition duration-500" />
            <img src="/images/fabrics/sitip-technical-textles-fabrics-2.webp" alt="Sitip Fabric Application" class="rounded-xl shadow-lg w-full h-64 object-cover transform translate-y-8 hover:scale-105 transition duration-500" />
          </div>
        </div>
        <div class="order-1 md:order-2">
          <h2 class="text-4xl font-extrabold text-navy-900 mb-6">Partnering with Sitip Italy</h2>
          <p class="text-gray-600 text-lg leading-relaxed mb-8">
            Sitip is a global leader in warp-knitted technical fabrics. We proudly utilize their advanced textiles to ensure our custom sportswear meets the rigorous demands of elite athletes. These fabrics provide exceptional stretch, recovery, and moisture management.
          </p>
          <ul class="space-y-4">
            <li class="flex items-center gap-3"><svg class="w-6 h-6 text-gold-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg><span class="text-navy-900 font-semibold">4-Way Stretch Technology</span></li>
            <li class="flex items-center gap-3"><svg class="w-6 h-6 text-gold-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg><span class="text-navy-900 font-semibold">Superior Moisture Wicking</span></li>
            <li class="flex items-center gap-3"><svg class="w-6 h-6 text-gold-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg><span class="text-navy-900 font-semibold">UV Protection (UPF 50+)</span></li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Certifications Section -->
  <section class="py-24 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-gold-500 font-bold uppercase tracking-widest text-sm mb-3">Sustainability & Safety</p>
      <h2 class="text-4xl font-extrabold text-navy-900 mb-16">Our Certifications</h2>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
        <!-- OEKO-TEX -->
        <div class="bg-white p-10 rounded-2xl shadow-sm hover:shadow-xl transition-shadow duration-300 group">
          <div class="h-24 flex items-center justify-center mb-6">
            <div class="w-20 h-20 bg-gray-100 rounded-full flex items-center justify-center group-hover:bg-gold-50 transition-colors">
              <svg class="w-10 h-10 text-navy-900" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
          </div>
          <h3 class="text-xl font-bold text-navy-900 mb-4">OEKO-TEX® Standard 100</h3>
          <p class="text-gray-600">Every component of our fabrics has been tested for harmful substances and is harmless in human ecological terms.</p>
        </div>
        
        <!-- Bluesign -->
        <div class="bg-white p-10 rounded-2xl shadow-sm hover:shadow-xl transition-shadow duration-300 group">
          <div class="h-24 flex items-center justify-center mb-6">
            <div class="w-20 h-20 bg-gray-100 rounded-full flex items-center justify-center group-hover:bg-blue-50 transition-colors">
              <img src="/images/hero/Ticker-Bluesign.png" alt="Bluesign" class="w-16 h-16 object-contain" />
            </div>
          </div>
          <h3 class="text-xl font-bold text-navy-900 mb-4">Bluesign® Approved</h3>
          <p class="text-gray-600">Manufactured with the lowest possible impact on people and the environment, ensuring responsible use of resources.</p>
        </div>
        
        <!-- GRS -->
        <div class="bg-white p-10 rounded-2xl shadow-sm hover:shadow-xl transition-shadow duration-300 group">
          <div class="h-24 flex items-center justify-center mb-6">
            <div class="w-20 h-20 bg-gray-100 rounded-full flex items-center justify-center group-hover:bg-green-50 transition-colors">
              <svg class="w-10 h-10 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
            </div>
          </div>
          <h3 class="text-xl font-bold text-navy-900 mb-4">Global Recycled Standard</h3>
          <p class="text-gray-600">We offer a wide range of fabrics made from recycled PET bottles, reducing plastic waste and carbon footprint.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-navy-900 text-center">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-white mb-6">Request a Fabric Swatch Book</h2>
      <p class="text-lg text-gray-400 mb-8">Feel the difference in quality. Contact us to request physical samples of our premium materials.</p>
      <a href="/contact-us" class="bg-gold-400 text-navy-900 hover:bg-gold-500 font-bold py-4 px-10 rounded-full uppercase tracking-wider transition-transform transform hover:-translate-y-1 inline-block">
        Request Samples
      </a>
    </div>
  </section>
</Layout>
