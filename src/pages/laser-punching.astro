---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Laser Cutting & Punching | ICM Factory Direct">
  <section class="relative pt-32 pb-24 bg-navy-900 overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img src="/images/process/MG_8933-2.png" alt="Laser Cutting" class="w-full h-full object-cover opacity-30" />
      <div class="absolute inset-0 bg-gradient-to-t from-navy-900 to-transparent"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center text-white">
      <p class="text-gold-400 font-bold uppercase tracking-[0.2em] text-sm mb-4">Precision Engineering</p>
      <h1 class="text-5xl md:text-6xl font-extrabold tracking-tight mb-6">Laser Punching</h1>
      <p class="text-xl max-w-3xl mx-auto text-gray-300 font-light leading-relaxed">
        Enhance breathability and add technical aesthetics with precise laser-cut ventilation.
      </p>
    </div>
  </section>

  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div class="relative">
          <div class="aspect-w-4 aspect-h-3 bg-gray-100 rounded-2xl overflow-hidden shadow-2xl border border-gray-200">
            <img src="/images/products/headwear/laser-cut-cap.jpg" alt="Laser Cut Cap" class="w-full h-full object-cover" onerror="this.src='/images/projects/2bu-brand.jpg'" />
          </div>
        </div>
        <div>
          <h2 class="text-4xl font-extrabold text-navy-900 mb-6">Advanced Ventilation</h2>
          <p class="text-gray-600 text-lg leading-relaxed mb-6">
            Laser punching (or laser perforation) allows us to create precise, clean-cut micro-holes in technical fabrics and headwear. This process dramatically increases airflow exactly where athletes need it most.
          </p>
          <ul class="space-y-4">
            <li class="flex items-center gap-3"><span class="text-gold-500 font-bold text-xl">✓</span><span class="text-gray-700">Strategic cooling zones</span></li>
            <li class="flex items-center gap-3"><span class="text-gold-500 font-bold text-xl">✓</span><span class="text-gray-700">Clean, sealed edges that won't fray</span></li>
            <li class="flex items-center gap-3"><span class="text-gold-500 font-bold text-xl">✓</span><span class="text-gray-700">Custom patterns and logo integrations</span></li>
            <li class="flex items-center gap-3"><span class="text-gold-500 font-bold text-xl">✓</span><span class="text-gray-700">High-tech aesthetic appeal</span></li>
          </ul>
          <div class="mt-8">
            <a href="/contact-us" class="bg-gold-400 text-navy-900 hover:bg-gold-500 px-8 py-3 rounded-full font-bold inline-block transition-transform transform hover:-translate-y-1">Discuss Technical Needs</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
