---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Reflective Materials | ICM Factory Direct">
  <section class="relative pt-32 pb-24 bg-navy-900 overflow-hidden text-center text-white">
    <p class="text-gold-400 font-bold uppercase tracking-[0.2em] text-sm mb-4">Safety Meets Style</p>
    <h1 class="text-5xl md:text-6xl font-extrabold tracking-tight mb-6">Reflective Details</h1>
    <p class="text-xl max-w-3xl mx-auto text-gray-300 font-light leading-relaxed">
      High-visibility reflective elements designed for night runners, cyclists, and safety gear.
    </p>
  </section>

  <section class="py-24 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div class="order-2 md:order-1">
          <h2 class="text-4xl font-extrabold text-navy-900 mb-6">Be Seen, Be Safe</h2>
          <p class="text-gray-600 text-lg leading-relaxed mb-6">
            Integrating 3M™ Scotchlite™ and other premium reflective materials into your sportswear enhances visibility in low-light conditions. Whether it's a marathon singlet, cycling bibs, or activewear, reflective detailing is crucial.
          </p>
          <ul class="space-y-4 text-gray-700">
            <li>✦ <strong>Reflective Heat Transfers:</strong> Logos and trims that shine bright when illuminated.</li>
            <li>✦ <strong>Reflective Piping:</strong> Sewn into seams for a subtle daytime look and high nighttime visibility.</li>
            <li>✦ <strong>Reflective Inks:</strong> Screen-printed designs with reflective properties.</li>
          </ul>
        </div>
        <div class="order-1 md:order-2">
          <div class="bg-gray-800 p-8 rounded-2xl shadow-xl flex items-center justify-center h-80">
            <!-- Simulated reflective effect -->
            <div class="text-white font-black text-4xl tracking-widest uppercase drop-shadow-[0_0_15px_rgba(255,255,255,0.8)] opacity-90 hover:opacity-100 hover:drop-shadow-[0_0_30px_rgba(255,255,255,1)] transition-all cursor-pointer">
              REFLECTIVE
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
