---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
---

<Layout title="Reflective Materials | ICM Factory Direct">
  <!-- Hero Section -->
  <PageHero
    title="Reflective Details"
    breadcrumbs={[
      { label: "Home", href: "/" },
      { label: "Product Features", href: "#" },
      { label: "Reflective Details" }
    ]}
    backgroundImage="/images/worker-in-textile-industry-sewing-FQEGPTY-1.jpg"
    overlayOpacity={0.6}
    overlayColor="#1D2F40"
  />

  <!-- Gallery Section - From XML -->
  <section class="py-[80px] bg-white">
    <div class="max-w-[1340px] mx-auto px-[15px]">
      <h4 class="font-heading text-[24px] font-semibold leading-[1.3] text-[#1D2F40] mb-8 text-center">* These items are for show purposes only and not for sale.</h4>
      
      <!-- Gallery Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- Reflective In Peak -->
        <div class="group relative overflow-hidden rounded-[10px] border border-[#A6587C]">
          <img src="/images/reflective-in-peak.png" alt="Reflective In Peak" class="w-full h-[300px] object-cover" />
          <div class="p-4 bg-[#1D2F40]">
            <h4 class="font-heading text-[18px] font-medium leading-[1.2] text-white text-center">Reflective In Peak</h4>
          </div>
        </div>

        <!-- Reflective In Peak - Darker -->
        <div class="group relative overflow-hidden rounded-[10px] border border-[#A6587C]">
          <img src="/images/reflective-in-peak-darker.png" alt="Reflective In Peak - Darker" class="w-full h-[300px] object-cover" />
          <div class="p-4 bg-[#1D2F40]">
            <h4 class="font-heading text-[18px] font-medium leading-[1.2] text-white text-center">Reflective In Peak - Darker</h4>
          </div>
        </div>

        <!-- Reflective Logo in Peak -->
        <div class="group relative overflow-hidden rounded-[10px] border border-[#A6587C]">
          <img src="/images/reflective-logo-in-peak.png" alt="Reflective Logo in Peak" class="w-full h-[300px] object-cover" />
          <div class="p-4 bg-[#1D2F40]">
            <h4 class="font-heading text-[18px] font-medium leading-[1.2] text-white text-center">Reflective Logo in Peak</h4>
          </div>
        </div>

        <!-- Reflective Closures -->
        <div class="group relative overflow-hidden rounded-[10px] border border-[#A6587C]">
          <img src="/images/reflective-closures.jpg" alt="Reflective Closures" class="w-full h-[300px] object-cover" />
          <div class="p-4 bg-[#1D2F40]">
            <h4 class="font-heading text-[18px] font-medium leading-[1.2] text-white text-center">Reflective Closures</h4>
          </div>
        </div>

        <!-- Custom Cap Design used Reflective -->
        <div class="group relative overflow-hidden rounded-[10px] border border-[#A6587C]">
          <img src="/images/reflective-custom-cap.jpg" alt="Custom Cap Design used Reflective" class="w-full h-[300px] object-cover" />
          <div class="p-4 bg-[#1D2F40]">
            <h4 class="font-heading text-[18px] font-medium leading-[1.2] text-white text-center">Custom Cap Design used Reflective</h4>
          </div>
        </div>

        <!-- Patch -->
        <div class="group relative overflow-hidden rounded-[10px] border border-[#A6587C]">
          <img src="/images/reflective-patch.jpg" alt="Patch" class="w-full h-[300px] object-cover" />
          <div class="p-4 bg-[#1D2F40]">
            <h4 class="font-heading text-[18px] font-medium leading-[1.2] text-white text-center">Patch</h4>
          </div>
        </div>

        <!-- Tape -->
        <div class="group relative overflow-hidden rounded-[10px] border border-[#A6587C]">
          <img src="/images/reflective-tape.jpg" alt="Tape" class="w-full h-[300px] object-cover" />
          <div class="p-4 bg-[#1D2F40]">
            <h4 class="font-heading text-[18px] font-medium leading-[1.2] text-white text-center">Tape</h4>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
