---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Sizing Charts | ICM Factory Direct">
  <section class="py-24 bg-white text-center">
    <div class="max-w-4xl mx-auto px-4">
      <h1 class="text-4xl md:text-5xl font-extrabold text-navy-900 mb-6">Sizing & Fit Guides</h1>
      <p class="text-xl text-gray-600 mb-12">
        Ensure the perfect fit for your custom apparel. Review our standard measurements below.
      </p>
      
      <div class="space-y-12 text-left">
        <!-- Men's Chart -->
        <div class="bg-gray-50 p-8 rounded-2xl shadow-sm border border-gray-200">
          <h2 class="text-2xl font-bold text-navy-900 mb-6 border-b pb-4">Men's Standard Sizing</h2>
          <div class="overflow-x-auto">
            <table class="w-full text-sm text-left text-gray-600">
              <thead class="text-xs text-white uppercase bg-navy-900">
                <tr>
                  <th class="px-6 py-4 rounded-tl-lg">Size</th>
                  <th class="px-6 py-4">Chest (in)</th>
                  <th class="px-6 py-4">Waist (in)</th>
                  <th class="px-6 py-4 rounded-tr-lg">Hip (in)</th>
                </tr>
              </thead>
              <tbody>
                <tr class="bg-white border-b">
                  <td class="px-6 py-4 font-bold">Small (S)</td>
                  <td class="px-6 py-4">35 - 37</td>
                  <td class="px-6 py-4">29 - 31</td>
                  <td class="px-6 py-4">35 - 37</td>
                </tr>
                <tr class="bg-gray-50 border-b">
                  <td class="px-6 py-4 font-bold">Medium (M)</td>
                  <td class="px-6 py-4">38 - 40</td>
                  <td class="px-6 py-4">32 - 34</td>
                  <td class="px-6 py-4">38 - 40</td>
                </tr>
                <tr class="bg-white border-b">
                  <td class="px-6 py-4 font-bold">Large (L)</td>
                  <td class="px-6 py-4">41 - 43</td>
                  <td class="px-6 py-4">35 - 37</td>
                  <td class="px-6 py-4">41 - 43</td>
                </tr>
                <tr class="bg-gray-50 border-b">
                  <td class="px-6 py-4 font-bold">X-Large (XL)</td>
                  <td class="px-6 py-4">44 - 46</td>
                  <td class="px-6 py-4">38 - 40</td>
                  <td class="px-6 py-4">44 - 46</td>
                </tr>
                <tr class="bg-white">
                  <td class="px-6 py-4 font-bold rounded-bl-lg">2X-Large (2XL)</td>
                  <td class="px-6 py-4">47 - 49</td>
                  <td class="px-6 py-4">41 - 43</td>
                  <td class="px-6 py-4 rounded-br-lg">47 - 49</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>

        <!-- Women's Chart -->
        <div class="bg-gray-50 p-8 rounded-2xl shadow-sm border border-gray-200">
          <h2 class="text-2xl font-bold text-navy-900 mb-6 border-b pb-4">Women's Standard Sizing</h2>
          <div class="overflow-x-auto">
            <table class="w-full text-sm text-left text-gray-600">
              <thead class="text-xs text-white uppercase bg-navy-900">
                <tr>
                  <th class="px-6 py-4 rounded-tl-lg">Size</th>
                  <th class="px-6 py-4">Chest (in)</th>
                  <th class="px-6 py-4">Waist (in)</th>
                  <th class="px-6 py-4 rounded-tr-lg">Hip (in)</th>
                </tr>
              </thead>
              <tbody>
                <tr class="bg-white border-b">
                  <td class="px-6 py-4 font-bold">X-Small (XS)</td>
                  <td class="px-6 py-4">31.5 - 32.5</td>
                  <td class="px-6 py-4">24 - 25</td>
                  <td class="px-6 py-4">34 - 35</td>
                </tr>
                <tr class="bg-gray-50 border-b">
                  <td class="px-6 py-4 font-bold">Small (S)</td>
                  <td class="px-6 py-4">33.5 - 34.5</td>
                  <td class="px-6 py-4">26 - 27</td>
                  <td class="px-6 py-4">36 - 37</td>
                </tr>
                <tr class="bg-white border-b">
                  <td class="px-6 py-4 font-bold">Medium (M)</td>
                  <td class="px-6 py-4">35.5 - 37.5</td>
                  <td class="px-6 py-4">28 - 30</td>
                  <td class="px-6 py-4">38 - 40</td>
                </tr>
                <tr class="bg-gray-50 border-b">
                  <td class="px-6 py-4 font-bold">Large (L)</td>
                  <td class="px-6 py-4">38.5 - 40.5</td>
                  <td class="px-6 py-4">31 - 33</td>
                  <td class="px-6 py-4">41 - 43</td>
                </tr>
                <tr class="bg-white">
                  <td class="px-6 py-4 font-bold rounded-bl-lg">X-Large (XL)</td>
                  <td class="px-6 py-4">41.5 - 44</td>
                  <td class="px-6 py-4">34 - 36.5</td>
                  <td class="px-6 py-4 rounded-br-lg">44 - 46.5</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
      
      <div class="mt-12 text-gray-500 italic">
        * Note: These are general guidelines. Custom sizing runs and specific fit options (Relaxed, Athletic, Compression) are available upon request.
      </div>
    </div>
  </section>
</Layout>
