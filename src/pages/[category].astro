---
import Layout from '../layouts/Layout.astro';
import { getAllCategories } from '../data/products';

export function getStaticPaths() {
  const categories = getAllCategories();
  return categories.map(category => ({
    params: { category: category.id },
    props: { category },
  }));
}

const { category } = Astro.props;
---

<Layout title={`${category.name} | ICM Factory Direct`}>
  <!-- Category Header -->
  <section class="relative py-24 md:py-32 bg-navy-900 overflow-hidden">
    <div class="absolute inset-0 z-0 opacity-30">
      <img src={category.image} alt={category.name} class="w-full h-full object-cover" onerror="this.src='/images/projects/2bu-brand.jpg'" />
    </div>
    <div class="absolute inset-0 bg-gradient-to-t from-navy-900 via-navy-900/80 to-transparent z-10"></div>
    <div class="relative z-20 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center text-white mt-10">
      <p class="text-gold-400 font-bold uppercase tracking-widest text-sm mb-4">Product Category</p>
      <h1 class="text-4xl md:text-6xl font-extrabold mb-6">{category.name}</h1>
      <p class="text-xl max-w-3xl mx-auto text-gray-300 leading-relaxed mb-8">
        {category.description}
      </p>
      {category.pdfBrochure && (
        <a href={category.pdfBrochure} target="_blank" class="inline-flex items-center gap-2 bg-gold-400 text-navy-900 hover:bg-gold-500 px-8 py-3.5 rounded-full font-bold transition-all shadow-lg">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          DOWNLOAD E-BROCHURE
        </a>
      )}
    </div>
  </section>

  <!-- Subcategories Listing -->
  <section class="py-24 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="flex mb-12 text-navy-900" aria-label="Breadcrumb">
        <ol class="inline-flex items-center space-x-1 md:space-x-3">
          <li class="inline-flex items-center">
            <a href="/" class="hover:text-gold-500 transition-colors">Home</a>
          </li>
          <li>
            <div class="flex items-center">
              <svg class="w-4 h-4 mx-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path></svg>
              <span class="text-navy-900 ml-1 md:ml-2 font-medium">{category.name}</span>
            </div>
          </li>
        </ol>
      </nav>
      {category.subcategories && category.subcategories.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
          {category.subcategories.map(sub => (
            <a href={`/${category.id}/${sub.id}`} class="bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 group block">
              <div class="aspect-w-4 aspect-h-5 bg-gray-100 overflow-hidden relative">
                <img 
                  src={sub.image} 
                  alt={sub.name} 
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" 
                  onerror="this.src='/images/projects/2bu-brand.jpg'" 
                />
                <div class="absolute inset-0 bg-navy-900/10 group-hover:bg-transparent transition-colors"></div>
              </div>
              <div class="p-6 text-center border-t border-gray-100">
                <h3 class="text-xl font-bold text-navy-900">{sub.name}</h3>
                {sub.description && <p class="text-gray-500 text-sm mt-2">{sub.description}</p>}
                <span class="inline-block mt-4 text-gold-500 text-sm font-bold tracking-widest uppercase opacity-0 group-hover:opacity-100 transition-opacity">View Details</span>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="text-center py-20 text-gray-500 text-lg">
          Products in this category are being updated. Check back soon!
        </div>
      )}
    </div>
  </section>

  <!-- CTA -->
  <section class="pt-32 pb-16 bg-gray-50 border-b border-gray-200 text-center">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-3xl md:text-4xl font-bold text-navy-900 mb-6">Need a Custom Quote for {category.name}?</h2>
      <p class="text-lg text-gray-600 mb-10">Contact our production specialists to discuss sizing, materials, and custom branding options.</p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/contact-us" class="bg-gold-400 hover:bg-gold-500 text-navy-900 font-bold py-3.5 px-8 rounded-full transition-transform transform hover:-translate-y-1 shadow-lg">
          REQUEST QUOTE
        </a>
        <a href="/products" class="bg-transparent border-2 border-navy-900 hover:bg-navy-900 hover:text-white text-navy-900 font-bold py-3.5 px-8 rounded-full transition-colors">
          BACK TO PRODUCTS
        </a>
      </div>
    </div>
  </section>
</Layout>
