---
import Layout from '../layouts/Layout.astro';
---

<Layout title="3D Configurator | ICM Factory Direct">
  <section class="py-24 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl font-extrabold text-navy-900 mb-6">Interactive 3D Configurator</h1>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto mb-12">
        Visualize your custom designs in real-time. Our 3D tool allows you to rotate, zoom, and customize garments before production begins.
      </p>
      
      <!-- 3D Configurator Embed Placeholder -->
      <div class="bg-white rounded-2xl shadow-2xl p-4 md:p-8 border border-gray-200">
        <div class="aspect-w-16 aspect-h-9 bg-gray-900 rounded-xl overflow-hidden relative flex items-center justify-center">
          <!-- In a real implementation, this would be an iframe or WebGL canvas -->
          <div class="text-center text-white p-8">
            <svg class="w-20 h-20 mx-auto text-gold-400 mb-4 animate-spin-slow" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14 10l-2 1m0 0l-2-1m2 1v2.5M20 7l-2 1m2-1l-2-1m2 1v2.5M14 4l-2-1-2 1M4 7l2-1M4 7l2 1M4 7v2.5M12 21l-2-1m2 1l2-1m-2 1v-2.5M6 18l-2-1v-2.5M18 18l2-1v-2.5"/></svg>
            <h2 class="text-2xl font-bold mb-2">3D Engine Loading...</h2>
            <p class="text-gray-400">Interactive viewer will initialize here.</p>
          </div>
        </div>
      </div>
      
      <div class="mt-16 grid md:grid-cols-3 gap-8 text-left">
        <div class="bg-white p-8 rounded-xl shadow-sm">
          <h3 class="text-xl font-bold text-navy-900 mb-3">Real-time Rendering</h3>
          <p class="text-gray-600">See pattern changes, color swaps, and logo placements instantly on a photorealistic 3D model.</p>
        </div>
        <div class="bg-white p-8 rounded-xl shadow-sm">
          <h3 class="text-xl font-bold text-navy-900 mb-3">360° Viewing</h3>
          <p class="text-gray-600">Rotate the garment to inspect every seam, panel, and detail from any angle.</p>
        </div>
        <div class="bg-white p-8 rounded-xl shadow-sm">
          <h3 class="text-xl font-bold text-navy-900 mb-3">Export Ready</h3>
          <p class="text-gray-600">Approve designs directly from the viewer and generate tech packs for immediate production.</p>
        </div>
      </div>
    </div>
  </section>
</Layout>
