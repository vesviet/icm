---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact Us | ICM Factory Direct">
  <!-- Hero Section -->
  <section class="relative pt-32 pb-24 bg-navy-900 overflow-hidden text-center text-white">
    <div class="absolute inset-0 z-0">
      <img src="/images/projects/Marriot.jpg" alt="Contact Us" class="w-full h-full object-cover opacity-20" onerror="this.src='/images/projects/2bu-brand.jpg'" />
      <div class="absolute inset-0 bg-gradient-to-t from-navy-900 to-transparent"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-gold-400 font-bold uppercase tracking-[0.2em] text-sm mb-4">Get In Touch</p>
      <h1 class="text-5xl md:text-6xl font-extrabold tracking-tight mb-6">Contact Us</h1>
      <p class="text-xl max-w-2xl mx-auto text-gray-300 font-light leading-relaxed">
        Ready to start your custom apparel project? Our team is here to answer your questions and provide a customized quote.
      </p>
    </div>
  </section>

  <section class="py-24 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16">
        
        <!-- Contact Information & Map -->
        <div>
          <h2 class="text-3xl font-extrabold text-navy-900 mb-8">Our Headquarters</h2>
          
          <div class="space-y-8 mb-12">
            <!-- Address -->
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-white rounded-full flex items-center justify-center flex-shrink-0 shadow-sm border border-gray-100 mt-1">
                <svg class="w-6 h-6 text-gold-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              </div>
              <div>
                <h4 class="text-xl font-bold text-navy-900 mb-2">Location</h4>
                <p class="text-gray-600">No. 2 Street, Binh Duong Industrial Park,<br />Di An Ward, Ho Chi Minh City, Vietnam</p>
              </div>
            </div>
            
            <!-- Email -->
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-white rounded-full flex items-center justify-center flex-shrink-0 shadow-sm border border-gray-100 mt-1">
                <svg class="w-6 h-6 text-gold-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              </div>
              <div>
                <h4 class="text-xl font-bold text-navy-900 mb-2">Email</h4>
                <a href="mailto:sales@interchinamanagement.com" class="text-gray-600 hover:text-gold-500 transition-colors">sales@interchinamanagement.com</a>
              </div>
            </div>
            
            <!-- Working Hours -->
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-white rounded-full flex items-center justify-center flex-shrink-0 shadow-sm border border-gray-100 mt-1">
                <svg class="w-6 h-6 text-gold-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              </div>
              <div>
                <h4 class="text-xl font-bold text-navy-900 mb-2">Working Hours</h4>
                <p class="text-gray-600">Monday - Friday: 8:00 AM - 5:00 PM (ICT)<br />Saturday & Sunday: Closed</p>
              </div>
            </div>

            <!-- Phone -->
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-white rounded-full flex items-center justify-center flex-shrink-0 shadow-sm border border-gray-100 mt-1">
                <svg class="w-6 h-6 text-gold-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              </div>
              <div>
                <h4 class="text-xl font-bold text-navy-900 mb-2">Phone</h4>
                <a href="tel:+842743791732" class="text-gray-600 hover:text-gold-500 transition-colors">+84 274 3791732</a>
              </div>
            </div>
            
            <!-- Social Icons -->
            <div class="flex gap-4 pt-2">
              <a href="https://www.facebook.com/icmfactorydirect" target="_blank" rel="noopener" class="w-10 h-10 bg-navy-900 hover:bg-gold-500 text-white flex items-center justify-center rounded-full transition-colors" aria-label="Facebook">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/></svg>
              </a>
              <a href="https://www.instagram.com/icmfactorydirect/" target="_blank" rel="noopener" class="w-10 h-10 bg-navy-900 hover:bg-gold-500 text-white flex items-center justify-center rounded-full transition-colors" aria-label="Instagram">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
              </a>
              <a href="https://www.youtube.com/@icmfactorydirect2921" target="_blank" rel="noopener" class="w-10 h-10 bg-navy-900 hover:bg-gold-500 text-white flex items-center justify-center rounded-full transition-colors" aria-label="YouTube">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
              </a>
            </div>
            
            <!-- Quick Links -->
            <div class="pt-6 border-t border-gray-200 mt-6">
              <h4 class="text-lg font-bold text-navy-900 mb-4">Quick Links</h4>
              <div class="flex flex-col gap-3">
                <a href="/headwear" class="text-gray-600 hover:text-gold-500 transition-colors flex items-center gap-2">
                  <svg class="w-4 h-4 text-gold-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                  Headwear
                </a>
                <a href="/mens-and-womens-wear" class="text-gray-600 hover:text-gold-500 transition-colors flex items-center gap-2">
                  <svg class="w-4 h-4 text-gold-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                  Men's & Women's Wear
                </a>
                <a href="/golf-resort" class="text-gray-600 hover:text-gold-500 transition-colors flex items-center gap-2">
                  <svg class="w-4 h-4 text-gold-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                  Golf & Resort
                </a>
              </div>
            </div>
          </div>
          
          <!-- Map Embed -->
          <div class="bg-gray-200 w-full h-64 rounded-xl overflow-hidden shadow-inner">
            <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3919.4241674197217!2d106.68744311480083!3d10.778788992319401!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x31752f305cf15ab9%3A0x8e8eb4dc5947fc9!2sHo%20Chi%20Minh%20City!5e0!3m2!1sen!2svn!4v1620000000000!5m2!1sen!2svn" width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy"></iframe>
          </div>
        </div>
        
        <!-- Contact Form -->
        <div class="bg-white p-8 md:p-12 rounded-2xl shadow-xl">
          <h2 class="text-3xl font-extrabold text-navy-900 mb-2">Send us a Message</h2>
          <p class="text-gray-500 mb-8">We will get back to you within 24 hours.</p>
          
          <!-- Note: Backend logic is skipped per user request. This will be implemented separately. -->
          <form class="space-y-6" onsubmit="event.preventDefault(); alert('Backend logic for form submission is pending implementation.');">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label for="firstName" class="block text-sm font-bold text-navy-900 mb-2">First Name *</label>
                <input type="text" id="firstName" name="firstName" required class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-gold-500 focus:ring-2 focus:ring-gold-500/20 outline-none transition-all bg-gray-50" placeholder="John" />
              </div>
              <div>
                <label for="lastName" class="block text-sm font-bold text-navy-900 mb-2">Last Name *</label>
                <input type="text" id="lastName" name="lastName" required class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-gold-500 focus:ring-2 focus:ring-gold-500/20 outline-none transition-all bg-gray-50" placeholder="Doe" />
              </div>
            </div>
            
            <div>
              <label for="email" class="block text-sm font-bold text-navy-900 mb-2">Email Address *</label>
              <input type="email" id="email" name="email" required class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-gold-500 focus:ring-2 focus:ring-gold-500/20 outline-none transition-all bg-gray-50" placeholder="john@example.com" />
            </div>
            
            <div>
              <label for="subject" class="block text-sm font-bold text-navy-900 mb-2">Subject</label>
              <select id="subject" name="subject" class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-gold-500 focus:ring-2 focus:ring-gold-500/20 outline-none transition-all bg-gray-50 appearance-none">
                <option value="General Inquiry">General Inquiry</option>
                <option value="Request a Quote">Request a Quote</option>
                <option value="Sample Request">Sample Request</option>
                <option value="Partnership">Partnership</option>
              </select>
            </div>
            
            <div>
              <label for="message" class="block text-sm font-bold text-navy-900 mb-2">Message *</label>
              <textarea id="message" name="message" rows="5" required class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-gold-500 focus:ring-2 focus:ring-gold-500/20 outline-none transition-all bg-gray-50 resize-y" placeholder="Tell us about your project requirements..."></textarea>
            </div>
            
            <button type="submit" class="w-full bg-navy-900 text-white hover:bg-gold-500 hover:text-navy-900 font-bold py-4 rounded-lg transition-colors uppercase tracking-wider text-sm">
              Send Message
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>
</Layout>
