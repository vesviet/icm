---
import Layout from '../../layouts/Layout.astro';
import { getAllCategories } from '../../data/products';

const categories = getAllCategories();
---

<Layout title="Products & Custom Sportswear | ICM Factory Direct">
  <!-- Page Header -->
  <section class="relative py-24 bg-navy-900 overflow-hidden">
    <div class="absolute inset-0 z-0 opacity-20">
      <img src="/images/cropped-image-of-dressmaker-sewing-cloth-with-sewi-WHDDWPP-1.jpg" alt="Products Background" class="w-full h-full object-cover" />
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center text-white">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold mb-6">Our Custom Products</h1>
      <p class="text-xl max-w-3xl mx-auto text-gray-300">
        Discover our extensive range of high-performance custom sportswear and corporate apparel.
        Tailored precisely to your brand's specifications.
      </p>
    </div>
  </section>

  <!-- Product Categories Grid -->
  <section class="py-24 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
        {categories.map((category) => (
          <a href={`/products/${category.id}`} class="group block">
            <div class="bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition-all duration-300 transform group-hover:-translate-y-1 h-full flex flex-col">
              <div class="aspect-w-16 aspect-h-10 relative overflow-hidden bg-gray-200">
                <img 
                  src={category.image} 
                  alt={category.name} 
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" 
                  onerror="this.src='/images/projects/2bu-brand.jpg'" 
                />
                <div class="absolute inset-0 bg-navy-900/20 group-hover:bg-transparent transition-colors duration-300"></div>
              </div>
              <div class="p-8 flex-grow flex flex-col">
                <h3 class="text-2xl font-bold text-navy-900 mb-3 group-hover:text-gold-500 transition-colors">
                  {category.name}
                </h3>
                <p class="text-gray-600 mb-6 flex-grow leading-relaxed">
                  {category.description}
                </p>
                <div class="flex items-center text-gold-500 font-bold uppercase tracking-wide text-sm mt-auto">
                  Explore Collection 
                  <svg class="w-5 h-5 ml-2 transform group-hover:translate-x-2 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Call to Action -->
  <section class="py-20 bg-white text-center border-t border-gray-100">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-navy-900 mb-4">Don't See What You Need?</h2>
      <p class="text-xl text-gray-600 mb-8">We offer fully custom manufacturing. If you have a specific design or technical requirement, our team can build it from scratch.</p>
      <a href="/contact-us" class="bg-navy-900 text-white hover:bg-gold-500 hover:text-navy-900 px-8 py-4 rounded-full font-bold text-sm uppercase tracking-wider transition-all inline-block shadow-lg">
        Discuss Custom Project
      </a>
    </div>
  </section>
</Layout>
