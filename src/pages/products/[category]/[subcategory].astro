---
import Layout from '../../../layouts/Layout.astro';
import { getAllCategories } from '../../../data/products';

export function getStaticPaths() {
  const categories = getAllCategories();
  let paths = [];
  categories.forEach(category => {
    category.subcategories.forEach(sub => {
      paths.push({
        params: { category: category.id, subcategory: sub.id },
        props: { category, subcategory: sub },
      });
    });
  });
  return paths;
}

const { category, subcategory } = Astro.props;

// Mock product images for the gallery
// In reality, this would be fetched from a database or a folder of images
const mockImages = Array.from({ length: 12 }).map((_, i) => ({
  id: `${subcategory.id}-${i+1}`,
  src: `/images/projects/2bu-brand.jpg`, // Placeholder
  alt: `${subcategory.name} Product ${i+1}`
}));
---

<Layout title={`${subcategory.name} | ${category.name} | ICM Factory Direct`}>
  <!-- Breadcrumbs & Header -->
  <section class="pt-32 pb-16 bg-navy-900 text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="flex text-sm text-gray-400 mb-6" aria-label="Breadcrumb">
        <ol class="inline-flex items-center space-x-1 md:space-x-3">
          <li class="inline-flex items-center">
            <a href="/products" class="hover:text-gold-400 transition-colors">Products</a>
          </li>
          <li>
            <div class="flex items-center">
              <svg class="w-4 h-4 mx-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path></svg>
              <a href={`/products/${category.id}`} class="hover:text-gold-400 transition-colors">{category.name}</a>
            </div>
          </li>
          <li aria-current="page">
            <div class="flex items-center">
              <svg class="w-4 h-4 mx-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path></svg>
              <span class="text-white ml-1 md:ml-2 font-medium">{subcategory.name}</span>
            </div>
          </li>
        </ol>
      </nav>
      
      <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-6">
        <div>
          <h1 class="text-4xl md:text-5xl font-extrabold mb-4">{subcategory.name}</h1>
          <p class="text-xl text-gray-300 max-w-2xl">{subcategory.description || `Explore our high-quality custom ${subcategory.name.toLowerCase()} options.`}</p>
        </div>
        <a href="/contact-us" class="bg-gold-400 text-navy-900 hover:bg-gold-500 px-8 py-3.5 rounded-full font-bold transition-all shadow-lg whitespace-nowrap">
          INQUIRE NOW
        </a>
      </div>
    </div>
  </section>

  <!-- Gallery -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Lightbox implementation could be added here -->
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-6">
        {mockImages.map((img) => (
          <div class="group relative aspect-w-4 aspect-h-5 bg-gray-100 rounded-lg overflow-hidden cursor-pointer shadow-sm hover:shadow-xl transition-all duration-300">
            <img 
              src={subcategory.image} 
              alt={img.alt} 
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" 
              onerror="this.src='/images/projects/2bu-brand.jpg'" 
            />
            <div class="absolute inset-0 bg-navy-900/0 group-hover:bg-navy-900/40 transition-colors duration-300 flex items-center justify-center">
              <svg class="w-10 h-10 text-white opacity-0 group-hover:opacity-100 transition-opacity duration-300 transform scale-50 group-hover:scale-100" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7"/></svg>
            </div>
          </div>
        ))}
      </div>
      
      <!-- Pagination/Load More (Placeholder) -->
      <div class="mt-16 text-center">
        <button class="bg-gray-100 hover:bg-gray-200 text-navy-900 font-bold py-3 px-8 rounded-full transition-colors">
          LOAD MORE
        </button>
      </div>
    </div>
  </section>
</Layout>
