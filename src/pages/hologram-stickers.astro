---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
---

<Layout title="Hologram Stickers | ICM Factory Direct">
  <!-- Hero Section -->
  <PageHero
    title="Hologram Stickers"
    breadcrumbs={[
      { label: "Home", href: "/" },
      { label: "Product Features", href: "#" },
      { label: "Hologram Stickers" }
    ]}
    backgroundImage="/images/worker-in-textile-industry-sewing-FQEGPTY-1.jpg"
    overlayOpacity={0.6}
    overlayColor="#1D2F40"
  />

  <section class="py-[80px] bg-white">
    <div class="max-w-[1340px] mx-auto px-[15px]">
      
      <!-- Gallery Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-16">
        <!-- Hologram Sticker ICM -->
        <div class="group relative overflow-hidden rounded-[10px] border border-[#A6587C]">
          <img src="/images/hologram-sticker-icm.jpg" alt="Hologram Sticker ICM" class="w-full h-[300px] object-cover" />
          <div class="p-4 bg-[#1D2F40]">
            <h4 class="font-heading text-[18px] font-medium leading-[1.2] text-white text-center">Hologram Sticker ICM</h4>
          </div>
        </div>

        <!-- Hologram Sticker Regna -->
        <div class="group relative overflow-hidden rounded-[10px] border border-[#A6587C]">
          <img src="/images/hologram-sticker-regna.jpg" alt="Hologram Sticker Regna" class="w-full h-[300px] object-cover" />
          <div class="p-4 bg-[#1D2F40]">
            <h4 class="font-heading text-[18px] font-medium leading-[1.2] text-white text-center">Hologram Sticker Regna</h4>
          </div>
        </div>

        <!-- Sticker Regna -->
        <div class="group relative overflow-hidden rounded-[10px] border border-[#A6587C]">
          <img src="/images/sticker-regna.jpg" alt="Sticker Regna" class="w-full h-[300px] object-cover" />
          <div class="p-4 bg-[#1D2F40]">
            <h4 class="font-heading text-[18px] font-medium leading-[1.2] text-white text-center">Sticker Regna</h4>
          </div>
        </div>

        <!-- Sticker ProX -->
        <div class="group relative overflow-hidden rounded-[10px] border border-[#A6587C]">
          <img src="/images/sticker-prox.jpg" alt="Sticker ProX" class="w-full h-[300px] object-cover" />
          <div class="p-4 bg-[#1D2F40]">
            <h4 class="font-heading text-[18px] font-medium leading-[1.2] text-white text-center">Sticker ProX</h4>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-[80px] bg-white">
    <div class="max-w-[1340px] mx-auto px-[15px]">
      
      <!-- Content -->
      <div class="max-w-4xl mx-auto text-center">
        <h3 class="font-heading text-[28px] md:text-[32px] font-semibold leading-[1.3] text-[#1D2F40] mb-6">
          Protect your brand and guarantee authenticity with custom holographic security stickers.
        </h3>
        
        <p class="font-body text-[17.6px] leading-[1.7] text-[#4A4A4A] mb-8">
          Counterfeiting is a growing issue for apparel brands. Hologram stickers provide a visually striking, hard-to-replicate layer of security that reassures your customers they are buying a genuine product.
        </p>
        
        <div class="flex justify-center mb-10">
          <ul class="text-left font-body text-[17.6px] leading-[1.7] text-[#4A4A4A] space-y-3">
            <li class="flex items-center">
              <span class="text-[#A6587C] mr-3">✓</span> Tamper-evident options
            </li>
            <li class="flex items-center">
              <span class="text-[#A6587C] mr-3">✓</span> Serialized numbering available
            </li>
            <li class="flex items-center">
              <span class="text-[#A6587C] mr-3">✓</span> Custom 3D brand logos
            </li>
            <li class="flex items-center">
              <span class="text-[#A6587C] mr-3">✓</span> Perfect for hang tags or polybags
            </li>
          </ul>
        </div>

        <div class="text-center">
          <a href="/contact-us/" class="inline-flex items-center justify-center border-2 border-[#1D2F40] text-[#1D2F40] hover:bg-[#1D2F40] hover:text-white font-nav text-[14px] font-semibold tracking-[2px] uppercase py-[12px] px-[30px] transition-colors">
            CONTACT US
          </a>
        </div>
      </div>
      
    </div>
  </section>
</Layout>
