---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
import { getAllCategories } from '../../data/products';

export function getStaticPaths() {
  const categories = getAllCategories();
  let paths: any[] = [];
  categories.forEach(category => {
    category.subcategories.forEach(sub => {
      paths.push({
        params: { category: category.id, subcategory: sub.id },
        props: { category, subcategory: sub },
      });
    });
  });
  return paths;
}

const { category, subcategory } = Astro.props;

const heroBackground = "/images/worker-in-textile-industry-sewing-FQEGPTY-1.jpg";

const hasGallery = subcategory.gallery && subcategory.gallery.length > 0;
const galleryItems = hasGallery
  ? subcategory.gallery
  : Array.from({ length: 8 }).map((_, i) => ({
      src: subcategory.image,
      label: `${subcategory.name} ${i + 1}`
    }));
---

<Layout title={`${subcategory.name} - ICM Factory Direct`}>
  <PageHero
    title={subcategory.name}
    backgroundImage={heroBackground}
    overlayOpacity={0.45}
    breadcrumbs={[
      { label: "Home", href: "/" },
      { label: category.name, href: `/${category.id}` },
      { label: subcategory.name }
    ]}
  />

  <!-- Disclaimer + Gallery -->
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-[1140px] mx-auto px-[15px]">
      <div class="text-center font-heading font-semibold italic text-navy-900 mb-12 max-w-4xl mx-auto">
        <p class="text-[18px] md:text-[20px] mb-2">* These products are for show purposes only and not for sale.</p>
        <p class="text-[14px] md:text-[16px] text-gray-600 font-normal not-italic mt-4">All logos, and their designs, used on our website are to show our product styles and capabilities only. They are not meant to be advertisements of any brands nor are of these items for sale to anyone other than the parties authorized by the owner of such logos &amp; designs.</p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6 md:gap-8">
        {galleryItems.map((item: any) => (
          <div class="group text-center">
            <div class="aspect-square bg-white rounded-lg overflow-hidden mb-4 border border-gray-100 hover:border-[#A6587C] transition-colors">
              <img
                src={item.src}
                alt={item.label || subcategory.name}
                class="w-full h-full object-contain p-4 transition-transform duration-500 group-hover:scale-105"
              />
            </div>
            {item.label && (
              <p class="font-heading text-[16px] font-medium text-navy-900 italic">{item.label}</p>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-gray-50 border-t border-gray-200">
    <div class="max-w-[900px] mx-auto px-[15px] text-center">
      <h2 class="font-heading text-[28px] md:text-[36px] font-semibold text-navy-900 mb-5">
        Interested in Custom {subcategory.name}?
      </h2>
      <p class="font-body text-[17.6px] text-gray-600 mb-10 leading-relaxed">
        Contact our production team to discuss materials, sizing, custom branding, and minimum order quantities.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/contact-us" class="inline-flex items-center gap-2 bg-[#A6587C] hover:bg-[#7D405C] text-white font-heading text-[16px] font-semibold px-8 py-3.5 rounded transition-colors">
          REQUEST A QUOTE
        </a>
        <a href={`/${category.id}`} class="inline-flex items-center gap-2 bg-transparent border-2 border-navy-900 hover:bg-navy-900 hover:text-white text-navy-900 font-heading text-[16px] font-semibold px-8 py-3.5 rounded transition-colors">
          BACK TO {category.name.toUpperCase()}
        </a>
      </div>
    </div>
  </section>
</Layout>
