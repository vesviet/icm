---
// Top Bar + Sticky Header Navigation with Mega Menu
---

<!-- TOP BAR -->
<div class="bg-white text-gray-700 text-sm py-2 border-b border-gray-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex justify-between items-center">
    <div class="flex items-center gap-6">
      <a href="mailto:sales@interchinamanagement.com" class="flex items-center gap-2 hover:text-[#A33B5B] transition-colors font-medium">
        <svg class="w-4 h-4 text-[#A33B5B]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
        sales@interchinamanagement.com
      </a>
      <div class="hidden sm:flex items-center gap-2 font-medium">
        <img src="https://flagcdn.com/w20/us.png" alt="USA Flag" class="w-5 h-auto rounded-sm shadow-sm" />
        An American Company
      </div>
    </div>
    <div class="flex items-center gap-2">
      <a href="https://www.facebook.com/icmfactorydirect" target="_blank" rel="noopener" class="bg-[#A33B5B] hover:bg-[#8A324C] text-white p-1.5 rounded-full transition-colors" aria-label="Facebook">
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/></svg>
      </a>
      <a href="https://www.instagram.com/icmfactorydirect/" target="_blank" rel="noopener" class="bg-[#A33B5B] hover:bg-[#8A324C] text-white p-1.5 rounded-full transition-colors" aria-label="Instagram">
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
      </a>
      <a href="https://www.youtube.com/@icmfactorydirect2921" target="_blank" rel="noopener" class="bg-[#A33B5B] hover:bg-[#8A324C] text-white p-1.5 rounded-full transition-colors" aria-label="YouTube">
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
      </a>
    </div>
  </div>
</div>

<!-- MAIN HEADER -->
<header class="sticky top-0 z-50 bg-navy-900/95 backdrop-blur-sm border-b border-white/10 shadow-lg">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">
      <!-- Logo -->
      <div class="flex-shrink-0">
        <a href="/" class="flex items-center">
          <img src="/images/logo.webp" alt="ICM Sportswear Factory Direct" class="h-8 md:h-10 w-auto" />
        </a>
      </div>

      <!-- Desktop Navigation -->
      <nav class="hidden lg:flex items-center gap-8 text-sm font-medium text-white">
        <a href="/#why-icm" class="hover:text-gold-400 transition-colors">About Us</a>
        
        <div class="relative group py-5">
          <button class="hover:text-gold-400 transition-colors flex items-center gap-1 focus:outline-none">
            Products
            <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </button>
          <div class="absolute top-full left-0 w-56 bg-white shadow-xl rounded-b-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 z-50 transform origin-top border-t-2 border-gold-400">
            <div class="py-2">
              <a href="/products/headwear" class="block px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 hover:text-gold-500 transition-colors">Custom Headwear</a>
              <a href="/products/mens-and-womens-wear" class="block px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 hover:text-gold-500 transition-colors">Men's & Women's Wear</a>
              <a href="/products/golf-resort" class="block px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 hover:text-gold-500 transition-colors">Golf & Resort</a>
              <a href="/products/cycling" class="block px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 hover:text-gold-500 transition-colors">Cycling</a>
              <a href="/products/triathlon" class="block px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 hover:text-gold-500 transition-colors">Triathlon</a>
              <a href="/products" class="block px-4 py-2.5 text-sm text-gold-500 hover:bg-gray-50 font-bold border-t border-gray-100 mt-1">View All Products</a>
            </div>
          </div>
        </div>

        <div class="relative group py-5">
          <button class="hover:text-gold-400 transition-colors flex items-center gap-1 focus:outline-none">
            Customization
            <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </button>
          <div class="absolute top-full left-0 w-48 bg-white shadow-xl rounded-b-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 z-50 transform origin-top border-t-2 border-gold-400">
            <div class="py-2">
              <a href="/fabrics" class="block px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 hover:text-gold-500 transition-colors">Premium Fabrics</a>
              <a href="/sublimation" class="block px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 hover:text-gold-500 transition-colors">Sublimation Printing</a>
              <a href="/laser-punching" class="block px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 hover:text-gold-500 transition-colors">Laser Punching</a>
              <a href="/reflective" class="block px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 hover:text-gold-500 transition-colors">Reflective Details</a>
              <a href="/hologram-stickers" class="block px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 hover:text-gold-500 transition-colors">Hologram Stickers</a>
              <a href="/hang-tags" class="block px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 hover:text-gold-500 transition-colors">Hang Tags</a>
            </div>
          </div>
        </div>

        <a href="/documents/ICM-eBrochure-2025.pdf" target="_blank" class="hover:text-gold-400 transition-colors">E-Brochures</a>
        
        <div class="relative group py-5">
          <button class="hover:text-gold-400 transition-colors flex items-center gap-1 focus:outline-none">
            High Tech
            <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </button>
          <div class="absolute top-full right-0 w-48 bg-white shadow-xl rounded-b-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 z-50 transform origin-top border-t-2 border-gold-400">
            <div class="py-2">
              <a href="/3d-configurator" class="block px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 hover:text-gold-500 transition-colors">3D Configurator</a>
              <a href="/sizing-charts" class="block px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 hover:text-gold-500 transition-colors">Sizing Charts</a>
            </div>
          </div>
        </div>

        <a href="/contact-us/" class="bg-gold-400 text-navy-900 px-5 py-2.5 rounded-full font-bold hover:bg-gold-500 hover:scale-105 transition-all shadow-lg ml-2">Contact Us</a>
      </nav>

      <!-- Mobile Menu Button -->
      <button id="mobile-menu-btn" class="lg:hidden text-white focus:outline-none" aria-label="Toggle Menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden lg:hidden bg-navy-800 border-t border-white/10">
    <div class="px-4 py-4 space-y-3">
      <a href="/#why-icm" class="block text-white hover:text-gold-400 py-2">About Us</a>
      <a href="/headwear/" class="block text-white hover:text-gold-400 py-2">Products</a>
      <a href="/fabrics/" class="block text-white hover:text-gold-400 py-2">Customization</a>
      <a href="/documents/ICM-eBrochure-2025.pdf" target="_blank" class="block text-white hover:text-gold-400 py-2">E-Brochures</a>
      <a href="/3d-configurator/" class="block text-white hover:text-gold-400 py-2">High Tech</a>
      <a href="/contact-us/" class="block text-center bg-gold-400 text-navy-900 px-5 py-2 rounded-full font-semibold mt-4">Contact Us</a>
    </div>
  </div>
</header>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    btn?.addEventListener('click', () => {
      menu?.classList.toggle('hidden');
    });
  });
</script>
