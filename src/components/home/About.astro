---
<section id="why-icm" class="reveal overflow-hidden py-[3em] px-[1em] bg-white">
  <div class="max-w-[1340px] w-full mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 items-center">
      
      <!-- Left Column: Overlapping Images Layout -->
      <div class="relative mr-0 lg:mr-[3em] p-[1em]">
        <!-- Image 1 (top-left, offset right) -->
        <div class="relative ml-[5em] z-[1]">
          <img src="/images/saleswoman-measures-fabric-in-textile-store-Z5W4B3B-1.jpg" alt="Custom Sportswear Manufacturer Vietnam" class="rounded-[10px] w-full h-auto" loading="lazy" />
        </div>
        
        <!-- Decorative border spacer (overlapping) -->
        <div class="relative -mt-[34em] mx-[2em] mr-[3em] h-[625px] border border-[#A6587C] rounded-[10px] z-0"></div>
        
        <!-- Image 2 (bottom-right, overlapping up) -->
        <div class="relative -mt-[10em] mr-[17em] z-[1]">
          <img src="/images/cropped-image-of-dressmaker-sewing-cloth-with-sewi-WHDDWPP-1.jpg" alt="Custom Sportswear Manufacturing Process" class="rounded-[10px] w-full h-auto" loading="lazy" />
        </div>
      </div>

      <!-- Right Column: Text Content -->
      <div class="p-[1em] flex flex-col justify-center">
        <h2 class="font-nav text-[14.4px] leading-[1] tracking-[2px] uppercase font-semibold text-[#A6587C] mb-[14px]">About ICM Factory Direct</h2>
        <h3 class="font-heading text-[36px] md:text-[52.8px] font-semibold leading-[1.2] text-[#1D2F40] mb-[16px] mr-0 lg:mr-[3em]">Empowering Performance, Inspiring Success.</h3>
        <p class="font-body text-[17.6px] leading-[1.5] text-[#757575] mb-[24px]">At ICM Factory Direct, we are passionate about empowering athletes and brands through our exceptional sportswear solutions. With a focus on innovation and quality, we offer a wide range of custom sportswear, tailored to elevate performance and inspire success.</p>

        <div class="grid grid-cols-1 md:grid-cols-2">
          <!-- Our Vision -->
          <div class="border-r-0 md:border-r md:border-[#A6587C] pr-0 md:pr-[1em]">
            <h4 class="font-heading text-[24px] font-medium leading-[1.2] text-[#1D2F40] mb-[10px]">Our Vision</h4>
            <ul class="space-y-[10px] -mt-[3%]">
              <li class="flex items-start gap-[8px]">
                <svg class="w-[17px] h-[17px] flex-shrink-0 mt-[3px] text-[#A6587C]" fill="currentColor" viewBox="0 0 512 512"><path d="M256 8C119.033 8 8 119.033 8 256s111.033 248 248 248 248-111.033 248-248S392.967 8 256 8zm0 48c110.532 0 200 89.451 200 200 0 110.532-89.451 200-200 200-110.532 0-200-89.451-200-200 0-110.532 89.451-200 200-200m140.204 130.267l-22.536-22.718c-4.667-4.705-12.265-4.736-16.97-.068L215.346 303.697l-59.792-60.277c-4.667-4.705-12.265-4.736-16.97-.069l-22.719 22.536c-4.705 4.667-4.736 12.265-.068 16.971l90.781 91.516c4.667 4.705 12.265 4.736 16.97.068l172.589-171.204c4.704-4.668 4.734-12.266.067-16.971z"/></svg>
                <span class="font-body text-[17.6px] leading-[1.5] text-[#757575]">Global leader in innovative sportswear solutions.</span>
              </li>
              <li class="flex items-start gap-[8px]">
                <svg class="w-[17px] h-[17px] flex-shrink-0 mt-[3px] text-[#A6587C]" fill="currentColor" viewBox="0 0 512 512"><path d="M256 8C119.033 8 8 119.033 8 256s111.033 248 248 248 248-111.033 248-248S392.967 8 256 8zm0 48c110.532 0 200 89.451 200 200 0 110.532-89.451 200-200 200-110.532 0-200-89.451-200-200 0-110.532 89.451-200 200-200m140.204 130.267l-22.536-22.718c-4.667-4.705-12.265-4.736-16.97-.068L215.346 303.697l-59.792-60.277c-4.667-4.705-12.265-4.736-16.97-.069l-22.719 22.536c-4.705 4.667-4.736 12.265-.068 16.971l90.781 91.516c4.667 4.705 12.265 4.736 16.97.068l172.589-171.204c4.704-4.668 4.734-12.266.067-16.971z"/></svg>
                <span class="font-body text-[17.6px] leading-[1.5] text-[#757575]">Inspiring athletes and brands to excel.</span>
              </li>
              <li class="flex items-start gap-[8px]">
                <svg class="w-[17px] h-[17px] flex-shrink-0 mt-[3px] text-[#A6587C]" fill="currentColor" viewBox="0 0 512 512"><path d="M256 8C119.033 8 8 119.033 8 256s111.033 248 248 248 248-111.033 248-248S392.967 8 256 8zm0 48c110.532 0 200 89.451 200 200 0 110.532-89.451 200-200 200-110.532 0-200-89.451-200-200 0-110.532 89.451-200 200-200m140.204 130.267l-22.536-22.718c-4.667-4.705-12.265-4.736-16.97-.068L215.346 303.697l-59.792-60.277c-4.667-4.705-12.265-4.736-16.97-.069l-22.719 22.536c-4.705 4.667-4.736 12.265-.068 16.971l90.781 91.516c4.667 4.705 12.265 4.736 16.97.068l172.589-171.204c4.704-4.668 4.734-12.266.067-16.971z"/></svg>
                <span class="font-body text-[17.6px] leading-[1.5] text-[#757575]">Redefining sportswear through design and sustainability.</span>
              </li>
              <li class="flex items-start gap-[8px]">
                <svg class="w-[17px] h-[17px] flex-shrink-0 mt-[3px] text-[#A6587C]" fill="currentColor" viewBox="0 0 512 512"><path d="M256 8C119.033 8 8 119.033 8 256s111.033 248 248 248 248-111.033 248-248S392.967 8 256 8zm0 48c110.532 0 200 89.451 200 200 0 110.532-89.451 200-200 200-110.532 0-200-89.451-200-200 0-110.532 89.451-200 200-200m140.204 130.267l-22.536-22.718c-4.667-4.705-12.265-4.736-16.97-.068L215.346 303.697l-59.792-60.277c-4.667-4.705-12.265-4.736-16.97-.069l-22.719 22.536c-4.705 4.667-4.736 12.265-.068 16.971l90.781 91.516c4.667 4.705 12.265 4.736 16.97.068l172.589-171.204c4.704-4.668 4.734-12.266.067-16.971z"/></svg>
                <span class="font-body text-[17.6px] leading-[1.5] text-[#757575]">Promoting health, wellness, and the joy of sports.</span>
              </li>
              <li class="flex items-start gap-[8px]">
                <svg class="w-[17px] h-[17px] flex-shrink-0 mt-[3px] text-[#A6587C]" fill="currentColor" viewBox="0 0 512 512"><path d="M256 8C119.033 8 8 119.033 8 256s111.033 248 248 248 248-111.033 248-248S392.967 8 256 8zm0 48c110.532 0 200 89.451 200 200 0 110.532-89.451 200-200 200-110.532 0-200-89.451-200-200 0-110.532 89.451-200 200-200m140.204 130.267l-22.536-22.718c-4.667-4.705-12.265-4.736-16.97-.068L215.346 303.697l-59.792-60.277c-4.667-4.705-12.265-4.736-16.97-.069l-22.719 22.536c-4.705 4.667-4.736 12.265-.068 16.971l90.781 91.516c4.667 4.705 12.265 4.736 16.97.068l172.589-171.204c4.704-4.668 4.734-12.266.067-16.971z"/></svg>
                <span class="font-body text-[17.6px] leading-[1.5] text-[#757575]">Creating a positive impact on lives and the environment.</span>
              </li>
            </ul>
          </div>

          <!-- Our Mission -->
          <div class="pl-0 md:pl-[3em] mt-[1em] md:mt-0">
            <h4 class="font-heading text-[24px] font-medium leading-[1.2] text-[#1D2F40] mb-[10px]">Our Mission</h4>
            <ul class="space-y-[10px] -mt-[3%]">
              <li class="flex items-start gap-[8px]">
                <svg class="w-[17px] h-[17px] flex-shrink-0 mt-[3px] text-[#A6587C]" fill="currentColor" viewBox="0 0 512 512"><path d="M256 8C119.033 8 8 119.033 8 256s111.033 248 248 248 248-111.033 248-248S392.967 8 256 8zm0 48c110.532 0 200 89.451 200 200 0 110.532-89.451 200-200 200-110.532 0-200-89.451-200-200 0-110.532 89.451-200 200-200m140.204 130.267l-22.536-22.718c-4.667-4.705-12.265-4.736-16.97-.068L215.346 303.697l-59.792-60.277c-4.667-4.705-12.265-4.736-16.97-.069l-22.719 22.536c-4.705 4.667-4.736 12.265-.068 16.971l90.781 91.516c4.667 4.705 12.265 4.736 16.97.068l172.589-171.204c4.704-4.668 4.734-12.266.067-16.971z"/></svg>
                <span class="font-body text-[17.6px] leading-[1.5] text-[#757575]">Designing cutting-edge sportswear for performance.</span>
              </li>
              <li class="flex items-start gap-[8px]">
                <svg class="w-[17px] h-[17px] flex-shrink-0 mt-[3px] text-[#A6587C]" fill="currentColor" viewBox="0 0 512 512"><path d="M256 8C119.033 8 8 119.033 8 256s111.033 248 248 248 248-111.033 248-248S392.967 8 256 8zm0 48c110.532 0 200 89.451 200 200 0 110.532-89.451 200-200 200-110.532 0-200-89.451-200-200 0-110.532 89.451-200 200-200m140.204 130.267l-22.536-22.718c-4.667-4.705-12.265-4.736-16.97-.068L215.346 303.697l-59.792-60.277c-4.667-4.705-12.265-4.736-16.97-.069l-22.719 22.536c-4.705 4.667-4.736 12.265-.068 16.971l90.781 91.516c4.667 4.705 12.265 4.736 16.97.068l172.589-171.204c4.704-4.668 4.734-12.266.067-16.971z"/></svg>
                <span class="font-body text-[17.6px] leading-[1.5] text-[#757575]">Collaborating for tailored brand solutions.</span>
              </li>
              <li class="flex items-start gap-[8px]">
                <svg class="w-[17px] h-[17px] flex-shrink-0 mt-[3px] text-[#A6587C]" fill="currentColor" viewBox="0 0 512 512"><path d="M256 8C119.033 8 8 119.033 8 256s111.033 248 248 248 248-111.033 248-248S392.967 8 256 8zm0 48c110.532 0 200 89.451 200 200 0 110.532-89.451 200-200 200-110.532 0-200-89.451-200-200 0-110.532 89.451-200 200-200m140.204 130.267l-22.536-22.718c-4.667-4.705-12.265-4.736-16.97-.068L215.346 303.697l-59.792-60.277c-4.667-4.705-12.265-4.736-16.97-.069l-22.719 22.536c-4.705 4.667-4.736 12.265-.068 16.971l90.781 91.516c4.667 4.705 12.265 4.736 16.97.068l172.589-171.204c4.704-4.668 4.734-12.266.067-16.971z"/></svg>
                <span class="font-body text-[17.6px] leading-[1.5] text-[#757575]">Upholding craftsmanship and quality.</span>
              </li>
              <li class="flex items-start gap-[8px]">
                <svg class="w-[17px] h-[17px] flex-shrink-0 mt-[3px] text-[#A6587C]" fill="currentColor" viewBox="0 0 512 512"><path d="M256 8C119.033 8 8 119.033 8 256s111.033 248 248 248 248-111.033 248-248S392.967 8 256 8zm0 48c110.532 0 200 89.451 200 200 0 110.532-89.451 200-200 200-110.532 0-200-89.451-200-200 0-110.532 89.451-200 200-200m140.204 130.267l-22.536-22.718c-4.667-4.705-12.265-4.736-16.97-.068L215.346 303.697l-59.792-60.277c-4.667-4.705-12.265-4.736-16.97-.069l-22.719 22.536c-4.705 4.667-4.736 12.265-.068 16.971l90.781 91.516c4.667 4.705 12.265 4.736 16.97.068l172.589-171.204c4.704-4.668 4.734-12.266.067-16.971z"/></svg>
                <span class="font-body text-[17.6px] leading-[1.5] text-[#757575]">Embracing sustainability in our practices.</span>
              </li>
              <li class="flex items-start gap-[8px]">
                <svg class="w-[17px] h-[17px] flex-shrink-0 mt-[3px] text-[#A6587C]" fill="currentColor" viewBox="0 0 512 512"><path d="M256 8C119.033 8 8 119.033 8 256s111.033 248 248 248 248-111.033 248-248S392.967 8 256 8zm0 48c110.532 0 200 89.451 200 200 0 110.532-89.451 200-200 200-110.532 0-200-89.451-200-200 0-110.532 89.451-200 200-200m140.204 130.267l-22.536-22.718c-4.667-4.705-12.265-4.736-16.97-.068L215.346 303.697l-59.792-60.277c-4.667-4.705-12.265-4.736-16.97-.069l-22.719 22.536c-4.705 4.667-4.736 12.265-.068 16.971l90.781 91.516c4.667 4.705 12.265 4.736 16.97.068l172.589-171.204c4.704-4.668 4.734-12.266.067-16.971z"/></svg>
                <span class="font-body text-[17.6px] leading-[1.5] text-[#757575]">Providing exceptional customer service.</span>
