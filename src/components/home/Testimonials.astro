        </div>

        <!-- Author Bio (bottom) -->
        <div class="flex flex-col items-center">
          <div class="w-[75px] h-[75px] rounded-full overflow-hidden mb-[5px]">
            <img src="/images/portrait-of-a-young-designer-standing-in-an-office-MX6TE8X-1.jpg" alt="Monica James" class="w-full h-full object-cover" loading="lazy" />
          </div>
          <strong class="font-heading text-[1.5rem] font-medium leading-[1.2] text-[#1D2F40] block mb-0">Monica James</strong>
          <span class="font-body text-[1.1rem] font-normal leading-[1.2] text-[#757575]">Entrepreneur</span>
        </div>
      </div>
    </div>
  </div>
</section>
