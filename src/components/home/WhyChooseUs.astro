---
---
<section id="why-icm" class="reveal overflow-hidden py-[3em] px-[1em] pb-[1em] bg-white">
  <div class="max-w-[1340px] w-full mx-auto">
    <div class="grid lg:grid-cols-2 items-center">
      <!-- Left Column: Text Content -->
      <div class="p-[1em]">
        <h2 class="font-nav text-[14.4px] font-semibold leading-[1] tracking-[2px] text-[#A6587C] uppercase mb-[14px]">WHY CHOOSE ICM FACTORY DIRECT</h2>
        <h3 class="font-heading text-[36px] md:text-[52.8px] font-semibold leading-[1.2] text-[#1D2F40] mb-[12px]">Delivering Excellence in Sportswear: Quality, Affordability, and Unmatched Service</h3>
        <p class="font-body text-[17.6px] leading-[1.5] text-[#757575] mb-[18px]">Choose ICM Factory Direct for your sportswear needs and experience the difference. We deliver high-end products crafted by skilled workers with 10+ years of experience, ensuring exceptional quality without compromising on our competitive pricing. With low minimum order quantities, you have the flexibility to manage your inventory efficiently.</p>
        <p class="font-body text-[17.6px] leading-[1.5] text-[#757575]">Our quick turnaround times, coupled with our 3D realistic design concepts, bring your vision to life. Enjoy customized solutions tailored to your brand's unique identity, all while maintaining affordability and unmatched quality. Trust ICM Factory Direct for sportswear that exceeds your expectations.</p>
      </div>
      
      <!-- Right Column: Pie Charts -->
      <div class="p-[1em]">
        <!-- Row 1 -->
        <div class="grid grid-cols-2">
          <!-- 95% Factory Experience -->
          <div class="text-center">
            <div class="relative w-[150px] h-[150px] mx-auto">
              <svg class="w-full h-full transform -rotate-90" viewBox="0 0 100 100">
                <circle cx="50" cy="50" r="45" fill="none" stroke="#1D2F40" stroke-width="5"></circle>
                <circle cx="50" cy="50" r="45" fill="none" stroke="#A6587C" stroke-width="5" stroke-dasharray="283" stroke-dashoffset="283" data-target="14.15" class="progress-circle transition-all duration-[2000ms] ease-out"></circle>
              </svg>
              <div class="absolute inset-0 flex items-center justify-center text-[30px] font-semibold text-[#1D2F40]">95%</div>
            </div>
            <h2 class="font-heading text-[22px] font-medium leading-[1.2] text-[#1D2F40] mt-2">Factory Experience</h2>
          </div>
          <!-- 97% Textile Material -->
          <div class="text-center">
            <div class="relative w-[150px] h-[150px] mx-auto">
              <svg class="w-full h-full transform -rotate-90" viewBox="0 0 100 100">
                <circle cx="50" cy="50" r="45" fill="none" stroke="#1D2F40" stroke-width="5"></circle>
                <circle cx="50" cy="50" r="45" fill="none" stroke="#A6587C" stroke-width="5" stroke-dasharray="283" stroke-dashoffset="283" data-target="8.49" class="progress-circle transition-all duration-[2000ms] ease-out"></circle>
              </svg>
              <div class="absolute inset-0 flex items-center justify-center text-[30px] font-semibold text-[#1D2F40]">97%</div>
            </div>
            <h2 class="font-heading text-[22px] font-medium leading-[1.2] text-[#1D2F40] mt-2">Textile Material</h2>
          </div>
        </div>

        <!-- Row 2 (margin-top: 2em) -->
        <div class="grid grid-cols-2 mt-[2em]">
          <!-- 96% Worker Skills -->
          <div class="text-center">
            <div class="relative w-[150px] h-[150px] mx-auto">
              <svg class="w-full h-full transform -rotate-90" viewBox="0 0 100 100">
                <circle cx="50" cy="50" r="45" fill="none" stroke="#1D2F40" stroke-width="5"></circle>
                <circle cx="50" cy="50" r="45" fill="none" stroke="#A6587C" stroke-width="5" stroke-dasharray="283" stroke-dashoffset="283" data-target="11.32" class="progress-circle transition-all duration-[2000ms] ease-out"></circle>
              </svg>
              <div class="absolute inset-0 flex items-center justify-center text-[30px] font-semibold text-[#1D2F40]">96%</div>
            </div>
            <h2 class="font-heading text-[22px] font-medium leading-[1.2] text-[#1D2F40] mt-2">Worker Skills</h2>
          </div>
          <!-- 93% Machinery & Equipment -->
          <div class="text-center">
            <div class="relative w-[150px] h-[150px] mx-auto">
              <svg class="w-full h-full transform -rotate-90" viewBox="0 0 100 100">
                <circle cx="50" cy="50" r="45" fill="none" stroke="#1D2F40" stroke-width="5"></circle>
                <circle cx="50" cy="50" r="45" fill="none" stroke="#A6587C" stroke-width="5" stroke-dasharray="283" stroke-dashoffset="283" data-target="19.81" class="progress-circle transition-all duration-[2000ms] ease-out"></circle>
              </svg>
              <div class="absolute inset-0 flex items-center justify-center text-[30px] font-semibold text-[#1D2F40]">93%</div>
            </div>
            <h2 class="font-heading text-[22px] font-medium leading-[1.2] text-[#1D2F40] mt-2">Machinery &amp; Equipment</h2>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const circles = entry.target.querySelectorAll('.progress-circle');
          circles.forEach(circle => {
            const target = circle.getAttribute('data-target');
            if (target) {
              setTimeout(() => {
                circle.setAttribute('stroke-dashoffset', target);
              }, 200);
            }
          });
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.3 });

    const section = document.getElementById('why-icm');
    if (section) observer.observe(section);
  });
</script>
