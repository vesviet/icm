---
---
<section id="why-choose-us" class="reveal py-[52.8px] bg-[#1D2F40]">
  <div class="max-w-[1340px] w-full mx-auto px-[10px]">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <!-- Info -->
      <div>
        <p class="font-nav text-[19.2px] font-semibold tracking-[2.5px] text-[#A6587C] uppercase mb-3">Why Choose Us</p>
        <h2 class="font-heading text-[52.8px] font-semibold leading-[1.2] text-white mb-6">WHY CHOOSE ICM FACTORY DIRECT</h2>
        <p class="font-body text-[17.6px] leading-[1.5] text-gray-300 mb-12">High-end products, low MOQ, quick turnaround, 3D design... Our state-of-the-art facilities and dedicated team ensure the highest quality standards, resulting in exceptional sportswear that exceeds expectations.</p>
      </div>
      
      <!-- Progress Circles -->
      <div>
        <div class="grid grid-cols-2 gap-8">
          <!-- 95% -->
          <div class="text-center group">
            <div class="relative w-32 h-32 mx-auto mb-4">
              <svg class="w-full h-full transform -rotate-90" viewBox="0 0 100 100">
                <circle cx="50" cy="50" r="45" fill="none" stroke="rgba(255,255,255,0.1)" stroke-width="6"></circle>
                <circle cx="50" cy="50" r="45" fill="none" stroke="#A6587C" stroke-width="6" stroke-dasharray="283" stroke-dashoffset="283" data-target="14.15" class="progress-circle transition-all duration-[2000ms] ease-out"></circle>
              </svg>
              <div class="absolute inset-0 flex items-center justify-center text-3xl font-bold text-white">95%</div>
            </div>
            <p class="font-semibold text-lg text-white uppercase tracking-wider">Factory Experience</p>
          </div>
          <!-- 97% -->
          <div class="text-center group">
            <div class="relative w-32 h-32 mx-auto mb-4">
              <svg class="w-full h-full transform -rotate-90" viewBox="0 0 100 100">
                <circle cx="50" cy="50" r="45" fill="none" stroke="rgba(255,255,255,0.1)" stroke-width="6"></circle>
                <circle cx="50" cy="50" r="45" fill="none" stroke="#A6587C" stroke-width="6" stroke-dasharray="283" stroke-dashoffset="283" data-target="8.49" class="progress-circle transition-all duration-[2000ms] ease-out"></circle>
              </svg>
              <div class="absolute inset-0 flex items-center justify-center text-3xl font-bold text-white">97%</div>
            </div>
            <p class="font-semibold text-lg text-white uppercase tracking-wider">Textile Material</p>
          </div>
          <!-- 96% -->
          <div class="text-center group">
            <div class="relative w-32 h-32 mx-auto mb-4">
              <svg class="w-full h-full transform -rotate-90" viewBox="0 0 100 100">
                <circle cx="50" cy="50" r="45" fill="none" stroke="rgba(255,255,255,0.1)" stroke-width="6"></circle>
                <circle cx="50" cy="50" r="45" fill="none" stroke="#A6587C" stroke-width="6" stroke-dasharray="283" stroke-dashoffset="283" data-target="11.32" class="progress-circle transition-all duration-[2000ms] ease-out"></circle>
              </svg>
              <div class="absolute inset-0 flex items-center justify-center text-3xl font-bold text-white">96%</div>
            </div>
            <p class="font-semibold text-lg text-white uppercase tracking-wider">Worker Skills</p>
          </div>
          <!-- 93% -->
          <div class="text-center group">
            <div class="relative w-32 h-32 mx-auto mb-4">
              <svg class="w-full h-full transform -rotate-90" viewBox="0 0 100 100">
                <circle cx="50" cy="50" r="45" fill="none" stroke="rgba(255,255,255,0.1)" stroke-width="6"></circle>
                <circle cx="50" cy="50" r="45" fill="none" stroke="#A6587C" stroke-width="6" stroke-dasharray="283" stroke-dashoffset="283" data-target="19.81" class="progress-circle transition-all duration-[2000ms] ease-out"></circle>
              </svg>
              <div class="absolute inset-0 flex items-center justify-center text-3xl font-bold text-white">93%</div>
            </div>
            <p class="font-semibold text-lg text-white uppercase tracking-wider">Machinery & Equipment</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const circles = entry.target.querySelectorAll('.progress-circle');
          circles.forEach(circle => {
            const target = circle.getAttribute('data-target');
            if (target) {
              setTimeout(() => {
                circle.setAttribute('stroke-dashoffset', target);
              }, 200);
            }
          });
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.3 });

    const section = document.getElementById('why-choose-us');
    if (section) observer.observe(section);
  });
</script>
