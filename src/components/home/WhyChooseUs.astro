---
---
<section class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <!-- Progress Circles -->
      <div>
        <p class="text-gold-500 font-bold uppercase tracking-widest text-sm mb-3">Why Choose Us</p>
        <h2 class="text-4xl md:text-5xl font-extrabold text-navy-900 mb-6">Expertise & Quality</h2>
        <p class="text-gray-600 mb-12 leading-relaxed">Our state-of-the-art facilities and dedicated team ensure the highest quality standards, resulting in exceptional sportswear that exceeds expectations.</p>
        
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-6">
          <!-- 95% -->
          <div class="text-center group">
            <div class="relative w-24 h-24 mx-auto mb-3">
              <svg class="w-full h-full transform -rotate-90" viewBox="0 0 100 100">
                <circle cx="50" cy="50" r="45" fill="none" stroke="#f3f4f6" stroke-width="8"></circle>
                <circle cx="50" cy="50" r="45" fill="none" stroke="#f0c040" stroke-width="8" stroke-dasharray="283" stroke-dashoffset="14.15" class="transition-all duration-1000 ease-out group-hover:stroke-navy-900"></circle>
              </svg>
              <div class="absolute inset-0 flex items-center justify-center text-xl font-bold text-navy-900">95%</div>
            </div>
            <p class="font-semibold text-sm text-gray-700">Factory</p>
          </div>
          <!-- 97% -->
          <div class="text-center group">
            <div class="relative w-24 h-24 mx-auto mb-3">
              <svg class="w-full h-full transform -rotate-90" viewBox="0 0 100 100">
                <circle cx="50" cy="50" r="45" fill="none" stroke="#f3f4f6" stroke-width="8"></circle>
                <circle cx="50" cy="50" r="45" fill="none" stroke="#f0c040" stroke-width="8" stroke-dasharray="283" stroke-dashoffset="8.49" class="transition-all duration-1000 ease-out group-hover:stroke-navy-900"></circle>
              </svg>
              <div class="absolute inset-0 flex items-center justify-center text-xl font-bold text-navy-900">97%</div>
            </div>
            <p class="font-semibold text-sm text-gray-700">Textile</p>
          </div>
          <!-- 96% -->
          <div class="text-center group">
            <div class="relative w-24 h-24 mx-auto mb-3">
              <svg class="w-full h-full transform -rotate-90" viewBox="0 0 100 100">
                <circle cx="50" cy="50" r="45" fill="none" stroke="#f3f4f6" stroke-width="8"></circle>
                <circle cx="50" cy="50" r="45" fill="none" stroke="#f0c040" stroke-width="8" stroke-dasharray="283" stroke-dashoffset="11.32" class="transition-all duration-1000 ease-out group-hover:stroke-navy-900"></circle>
              </svg>
              <div class="absolute inset-0 flex items-center justify-center text-xl font-bold text-navy-900">96%</div>
            </div>
            <p class="font-semibold text-sm text-gray-700">Workers</p>
          </div>
          <!-- 93% -->
          <div class="text-center group">
            <div class="relative w-24 h-24 mx-auto mb-3">
              <svg class="w-full h-full transform -rotate-90" viewBox="0 0 100 100">
                <circle cx="50" cy="50" r="45" fill="none" stroke="#f3f4f6" stroke-width="8"></circle>
                <circle cx="50" cy="50" r="45" fill="none" stroke="#f0c040" stroke-width="8" stroke-dasharray="283" stroke-dashoffset="19.81" class="transition-all duration-1000 ease-out group-hover:stroke-navy-900"></circle>
              </svg>
              <div class="absolute inset-0 flex items-center justify-center text-xl font-bold text-navy-900">93%</div>
            </div>
            <p class="font-semibold text-sm text-gray-700">Machinery</p>
          </div>
        </div>
      </div>
      
      <!-- Testimonial -->
      <div class="bg-gray-50 p-10 md:p-14 rounded-2xl relative">
        <svg class="absolute top-8 left-8 w-12 h-12 text-gold-400/30" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
        <div class="relative z-10">
          <p class="text-xl md:text-2xl font-light text-navy-900 leading-relaxed italic mb-8">
            "ICM Factory Direct has been a crucial partner for our brand. Their attention to detail, quality of materials, and quick turnaround times have helped us scale seamlessly."
          </p>
          <div class="flex items-center gap-4">
            <div class="w-14 h-14 bg-gray-300 rounded-full overflow-hidden">
              <img src="/images/portrait-of-a-young-designer-standing-in-an-office-MX6TE8X-1.jpg" alt="Monica James" class="w-full h-full object-cover" />
            </div>
            <div>
              <h4 class="font-bold text-navy-900">Monica James</h4>
              <p class="text-sm text-gold-500 font-semibold">Entrepreneur</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
