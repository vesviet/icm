---
---
<section class="reveal relative py-[105.6px] bg-[#1D2F40] overflow-hidden">
  <!-- BG Image with Overlay -->
  <div class="absolute inset-0">
    <img src="/images/professional-sewing-machine-close-up-modern-textil-F9BVMW7-1.jpg" alt="Factory" class="w-full h-full object-cover object-center" />
  </div>
  <div class="absolute inset-0 bg-[#1D2F40]/50"></div>
  
  <div class="relative z-10 max-w-[1340px] w-full mx-auto px-[10px]">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-[28px] md:gap-[20px] items-center text-center">
      <div class="lg:text-left">
        <h3 class="font-heading text-[38px] md:text-[44px] lg:text-[50px] font-semibold leading-[1.2] text-[#F4F4F4]">
          Our Factory In Number
        </h3>
      </div>

      <!-- Counter 1 -->
      <div>
        <h2 class="font-heading text-[52.8px] font-semibold leading-[1.1] text-[#F4F4F4] mb-[8px]">
          <span class="counter" data-target="29">0</span>
        </h2>
        <p class="font-heading text-[24px] font-medium leading-[1.2] text-[#F4F4F4]">Years Experience</p>
      </div>
      <!-- Counter 2 -->
      <div>
        <h2 class="font-heading text-[52.8px] font-semibold leading-[1.1] text-[#F4F4F4] mb-[8px]">
          <span class="counter" data-target="81">0</span>
        </h2>
        <p class="font-heading text-[24px] font-medium leading-[1.2] text-[#F4F4F4]">Export Countries</p>
      </div>
      <!-- Counter 3 -->
      <div>
        <h2 class="font-heading text-[52.8px] font-semibold leading-[1.1] text-[#F4F4F4] mb-[8px]">
          <span class="counter" data-target="0">0</span><span class="font-body text-[24px] font-semibold align-middle ml-1">Millions +</span>
        </h2>
        <p class="font-heading text-[24px] font-medium leading-[1.2] text-[#F4F4F4]">Garment Items</p>
      </div>
    </div>
  </div>
</section>

<script>
  // Counter Animation Logic
  document.addEventListener('DOMContentLoaded', () => {
    const counters = document.querySelectorAll('.counter');
    const speed = 200;

    const animateCounters = (entries, observer) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const counter = entry.target;
          const updateCount = () => {
            const target = +counter.getAttribute('data-target');
            const count = +counter.innerText;
            const inc = target / speed;

            if (count < target) {
              counter.innerText = Math.ceil(count + inc);
              setTimeout(updateCount, 20);
            } else {
              counter.innerText = target;
            }
          };
          updateCount();
          observer.unobserve(counter);
        }
      });
    };

    const observer = new IntersectionObserver(animateCounters, {
      threshold: 0.5
    });

    counters.forEach(counter => {
      observer.observe(counter);
    });
  });
</script>
