---
---
<section class="reveal relative py-[52.8px] bg-navy-900 overflow-hidden">
  <!-- BG Image with Overlay -->
  <div class="absolute inset-0 opacity-20">
    <img src="/images/saleswoman-measures-fabric-in-textile-store-Z5W4B3B-1.jpg" alt="Factory" class="w-full h-full object-cover" />
  </div>
  
  <div class="relative z-10 max-w-[1340px] w-full mx-auto px-[10px]">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 text-center">
      <!-- Counter 1 -->
      <div>
        <h2 class="text-[52.8px] font-semibold leading-[1.2] text-gold-400 mb-4">
          <span class="counter" data-target="29">0</span>
        </h2>
        <p class="text-2xl font-medium text-white">Years Experience</p>
      </div>
      <!-- Counter 2 -->
      <div>
        <h2 class="text-[52.8px] font-semibold leading-[1.2] text-gold-400 mb-4">
          <span class="counter" data-target="81">0</span>
        </h2>
        <p class="text-2xl font-medium text-white">Countries Shipped To</p>
      </div>
      <!-- Counter 3 -->
      <div>
        <h2 class="text-[52.8px] font-semibold leading-[1.2] text-gold-400 mb-4">
          <span class="counter" data-target="20">0</span><span class="text-5xl">+</span>
        </h2>
        <p class="text-2xl font-medium text-white">Millions of Items Produced</p>
      </div>
    </div>
  </div>
</section>

<script>
  // Counter Animation Logic
  document.addEventListener('DOMContentLoaded', () => {
    const counters = document.querySelectorAll('.counter');
    const speed = 200;

    const animateCounters = (entries, observer) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const counter = entry.target;
          const updateCount = () => {
            const target = +counter.getAttribute('data-target');
            const count = +counter.innerText;
            const inc = target / speed;

            if (count < target) {
              counter.innerText = Math.ceil(count + inc);
              setTimeout(updateCount, 20);
            } else {
              counter.innerText = target;
            }
          };
          updateCount();
          observer.unobserve(counter);
        }
      });
    };

    const observer = new IntersectionObserver(animateCounters, {
      threshold: 0.5
    });

    counters.forEach(counter => {
      observer.observe(counter);
    });
  });
</script>
