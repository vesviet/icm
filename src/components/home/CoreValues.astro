<section class="relative z-20 max-w-[1340px] w-full mx-auto px-[10px] -mt-16 sm:-mt-24 mb-16">
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    <!-- Card 1 -->
    <div class="p-8 hover:-translate-y-2 transition-transform duration-300 flex flex-col items-center text-center">
      <div class="h-[75px] w-[75px] mb-6">
        <img src="/images/services/Icon-1-1.png" alt="Excellent Material" class="w-full h-full object-contain" />
      </div>
      <h3 class="font-heading text-[24px] font-medium leading-[1.2] text-[#1D2F40] mb-4">Excellent Material</h3>
      <p class="font-body text-[16px] leading-[1.5] text-[#7A7A7A]">We source and utilize premium materials, ensuring our sportswear delivers unmatched comfort, durability, and performance.</p>
    </div>
    
    <!-- Card 2 -->
    <div class="p-8 hover:-translate-y-2 transition-transform duration-300 flex flex-col items-center text-center">
      <div class="h-[75px] w-[75px] mb-6">
        <img src="/images/services/Icon-2-1.png" alt="Quality Product" class="w-full h-full object-contain" />
