---
<section class="relative z-20 max-w-[1340px] w-full mx-auto px-[10px] -mt-[7em] mb-[56px] sm:mb-[64px]">
  <div class="grid grid-cols-1 md:grid-cols-3">
    <!-- Card 1 -->
    <div class="bg-[#1D2F40] rounded-[10px] m-[1em] p-[3em] flex items-start gap-[20px] transition-all duration-300">
      <div class="w-[25%] flex-shrink-0">
        <img src="/images/services/Icon-1-1.png" alt="Excellent Material" class="w-full h-auto object-contain" />
      </div>
      <div>
        <h3 class="font-heading text-[24px] font-medium leading-[1.2] text-[#F4F4F4] mb-[5px]">Excellent Material</h3>
        <p class="font-body text-[17.6px] leading-[1.5] text-[#D9D9D9]">We source and utilize premium materials, ensuring our sportswear delivers unmatched comfort, durability, and performance.</p>
      </div>
    </div>
    
    <!-- Card 2 -->
    <div class="bg-[#1D2F40] rounded-[10px] m-[1em] p-[3em] flex items-start gap-[20px] transition-all duration-300">
      <div class="w-[25%] flex-shrink-0">
        <img src="/images/services/Icon-2-1.png" alt="Quality Product" class="w-full h-auto object-contain" />
      </div>
      <div>
        <h3 class="font-heading text-[24px] font-medium leading-[1.2] text-[#F4F4F4] mb-[5px]">Quality Product</h3>
        <p class="font-body text-[17.6px] leading-[1.5] text-[#D9D9D9]">Our meticulous attention to detail and stringent quality control processes ensure that every product leaving our factory meets the highest standards of excellence.</p>
      </div>
    </div>

    <!-- Card 3 -->
    <div class="bg-[#1D2F40] rounded-[10px] m-[1em] p-[3em] flex items-start gap-[20px] transition-all duration-300">
      <div class="w-[25%] flex-shrink-0">
        <img src="/images/services/Icon-3-1.png" alt="Trusted by Clients" class="w-full h-auto object-contain" />
      </div>
      <div>
        <h3 class="font-heading text-[24px] font-medium leading-[1.2] text-[#F4F4F4] mb-[5px]">Trusted by Clients</h3>
        <p class="font-body text-[17.6px] leading-[1.5] text-[#D9D9D9]">20 years track record of delivering exceptional sportswear solutions has earned us the trust and loyalty of numerous satisfied clients worldwide</p>
      </div>
    </div>
  </div>
</section>

