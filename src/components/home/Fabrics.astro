---
<section class="reveal py-[52.8px] bg-white">
  <div class="max-w-[1340px] w-full mx-auto px-[10px]">
    <div class="text-center mb-16">
      <h2 class="font-heading text-[52.8px] font-semibold leading-[1.2] text-navy-900">FABRICS – Excellent Material</h2>
    </div>
    <div class="grid md:grid-cols-3 gap-8">
      <a href="/fabrics/" class="block group">
        <div class="rounded-xl overflow-hidden shadow-lg mb-6 bg-gray-50 aspect-video">
          <img src="/images/fabrics/sitip-technical-textles-fabrics-1.webp" alt="Sitip Fabric" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
        </div>
        <h3 class="font-heading text-[24px] font-medium leading-[1.2] text-navy-900 group-hover:text-gold-500 transition-colors">Sitip Italy Fabric</h3>
      </a>
      <a href="/fabrics/" class="block group">
        <div class="rounded-xl overflow-hidden shadow-lg mb-6 bg-gray-50 aspect-video">
          <img src="/images/fabrics/sitip-technical-textles-fabrics-2.webp" alt="Lightweight Fabric" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
        </div>
        <h3 class="font-heading text-[24px] font-medium leading-[1.2] text-navy-900 group-hover:text-gold-500 transition-colors">Lightweight - Breathable</h3>
      </a>
      <a href="/fabrics/" class="block group">
        <div class="rounded-xl overflow-hidden shadow-lg mb-6 bg-gray-50 aspect-video">
          <img src="/images/fabrics/sitip-technical-textles-fabrics-3.webp" alt="Certifications" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
        </div>
        <h3 class="font-heading text-[24px] font-medium leading-[1.2] text-navy-900 group-hover:text-gold-500 transition-colors">OEKO-TEX / Bluesign / GRS</h3>
      </a>
    </div>
  </div>
</section>
