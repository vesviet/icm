---
---
<section class="py-24 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <p class="text-gold-500 font-bold uppercase tracking-widest text-sm mb-3">What We Offer</p>
      <h2 class="text-4xl md:text-5xl font-extrabold text-navy-900">Our Services</h2>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <!-- Service 1 -->
      <div class="bg-white p-10 rounded-xl shadow-lg hover:shadow-xl transition-shadow text-center group">
        <div class="h-20 flex justify-center items-center mb-6">
          <img src="/images/services/Service-1-1.png" alt="Custom Design" class="h-16 object-contain group-hover:scale-110 transition-transform duration-300" />
        </div>
        <h3 class="text-xl font-bold text-navy-900 mb-4">Custom Design</h3>
        <p class="text-gray-600 leading-relaxed">Bring your vision to life. Our design team works with you to create unique, high-performance sportswear.</p>
      </div>
      <!-- Service 2 -->
      <div class="bg-white p-10 rounded-xl shadow-lg hover:shadow-xl transition-shadow text-center group">
        <div class="h-20 flex justify-center items-center mb-6">
          <img src="/images/services/Service-2-1.png" alt="Custom Fit" class="h-16 object-contain group-hover:scale-110 transition-transform duration-300" />
        </div>
        <h3 class="text-xl font-bold text-navy-900 mb-4">Custom Fit</h3>
        <p class="text-gray-600 leading-relaxed">Tailored to perfection. We provide advanced sizing and fit solutions for every body type.</p>
      </div>
      <!-- Service 3 -->
      <div class="bg-white p-10 rounded-xl shadow-lg hover:shadow-xl transition-shadow text-center group">
        <div class="h-20 flex justify-center items-center mb-6">
          <img src="/images/services/Service-3-1.png" alt="Private Label" class="h-16 object-contain group-hover:scale-110 transition-transform duration-300" />
        </div>
        <h3 class="text-xl font-bold text-navy-900 mb-4">Private Label</h3>
        <p class="text-gray-600 leading-relaxed">Your brand, front and center. Full white-label manufacturing to elevate your brand identity.</p>
      </div>
      <!-- Service 4 -->
      <div class="bg-white p-10 rounded-xl shadow-lg hover:shadow-xl transition-shadow text-center group">
        <div class="h-20 flex justify-center items-center mb-6">
          <img src="/images/services/Service-4-1.png" alt="Performance Enhancement" class="h-16 object-contain group-hover:scale-110 transition-transform duration-300" />
        </div>
        <h3 class="text-xl font-bold text-navy-900 mb-4">Performance Enhancement</h3>
        <p class="text-gray-600 leading-relaxed">Advanced fabrics and tech integrated into every garment to maximize athletic output.</p>
      </div>
      <!-- Service 5 -->
      <div class="bg-white p-10 rounded-xl shadow-lg hover:shadow-xl transition-shadow text-center group">
        <div class="h-20 flex justify-center items-center mb-6">
          <img src="/images/services/Service-5-1.png" alt="Sublimation Printing" class="h-16 object-contain group-hover:scale-110 transition-transform duration-300" />
        </div>
        <h3 class="text-xl font-bold text-navy-900 mb-4">Sublimation Printing</h3>
        <p class="text-gray-600 leading-relaxed">Vibrant, fade-resistant, and breathable full-color printing technology.</p>
      </div>
      <!-- Service 6 -->
      <div class="bg-white p-10 rounded-xl shadow-lg hover:shadow-xl transition-shadow text-center group">
        <div class="h-20 flex justify-center items-center mb-6">
          <img src="/images/services/Service-6-1.png" alt="Quick Turnaround" class="h-16 object-contain group-hover:scale-110 transition-transform duration-300" />
        </div>
        <h3 class="text-xl font-bold text-navy-900 mb-4">Quick Turnaround</h3>
        <p class="text-gray-600 leading-relaxed">Efficient production cycles ensuring your products reach the market faster.</p>
      </div>
    </div>
  </div>
</section>
