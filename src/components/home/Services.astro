---
---
<section class="reveal relative overflow-hidden py-[3em] px-[1em] bg-white" id="our-services">
  <!-- Background overlay pattern -->
  <div class="absolute inset-0 bg-[url('/images/BG-2-1.png')] bg-center bg-cover opacity-[0.2] pointer-events-none"></div>
  
  <div class="relative max-w-[1340px] w-full mx-auto">
    <div class="p-[1em]">
      <div class="text-center mb-0">
        <h2 class="font-nav text-[14.4px] font-semibold leading-[1] tracking-[2px] text-[#A6587C] uppercase mb-[14px]">Our Service</h2>
        <h3 class="font-heading text-[36px] md:text-[52.8px] font-semibold leading-[1.2] text-[#1D2F40] mb-4">Sportswear is What We Make</h3>
        <p class="font-body text-[17.6px] leading-[1.5] text-[#757575] mx-[17em] text-center">We design and manufacture cutting-edge sportswear that combines style, comfort, and performance.</p>
      </div>
      
      <!-- Row 1 -->
      <div class="grid grid-cols-1 md:grid-cols-3 -mt-[1em]">
        <!-- Custom Design -->
        <div class="bg-[#F4F4F4] border border-[#1D2F40] rounded-[10px] m-[1em] p-[3em] text-start group transition-all duration-300 hover:border-[#A6587C]">
          <div class="mb-[5px]">
            <img src="/images/services/Service-2-1.png" alt="Custom Design" class="w-[17%] min-w-[68px] object-contain transition-transform duration-300 group-hover:scale-110" loading="lazy" />
          </div>
          <h4 class="font-heading text-[24px] font-medium leading-[1.2] text-[#1D2F40] mb-[5px]">Custom Design</h4>
          <p class="font-body text-[17.6px] leading-[1.5] text-[#757575]">Collaborate with our experienced designers to create unique and eye-catching sportswear designs that reflect your brand and vision.</p>
        </div>

        <!-- Custom Fit -->
        <div class="bg-[#F4F4F4] border border-[#A6587C] rounded-[10px] m-[1em] p-[3em] text-start group transition-all duration-300 hover:border-[#1D2F40]">
          <div class="mb-[5px]">
            <img src="/images/services/Service-3-1.png" alt="Custom Fit" class="w-[17%] min-w-[68px] object-contain transition-transform duration-300 group-hover:scale-110" loading="lazy" />
          </div>
          <h4 class="font-heading text-[24px] font-medium leading-[1.2] text-[#1D2F40] mb-[5px]">Custom Fit</h4>
          <p class="font-body text-[17.6px] leading-[1.5] text-[#757575]">Enjoy the perfect fit with our tailored sportswear options, ensuring optimal comfort and freedom of movement for athletes of all shapes and sizes.</p>
        </div>

        <!-- Private Label -->
        <div class="bg-[#F4F4F4] border border-[#A6587C] rounded-[10px] m-[1em] p-[3em] text-start group transition-all duration-300 hover:border-[#1D2F40]">
          <div class="mb-[5px]">
            <img src="/images/services/Service-6-1.png" alt="Private Label" class="w-[17%] min-w-[68px] object-contain transition-transform duration-300 group-hover:scale-110" loading="lazy" />
          </div>
          <h4 class="font-heading text-[24px] font-medium leading-[1.2] text-[#1D2F40] mb-[5px]">Private Label</h4>
          <p class="font-body text-[17.6px] leading-[1.5] text-[#757575]">Benefit from our expertise in private label manufacturing, where we can produce sportswear under your brand name, providing a seamless and professional solution.</p>
        </div>
      </div>

      <!-- Row 2 -->
      <div class="grid grid-cols-1 md:grid-cols-3">
        <!-- Performance Enhancement -->
        <div class="bg-[#F4F4F4] border border-[#A6587C] rounded-[10px] m-[1em] p-[3em] text-start group transition-all duration-300 hover:border-[#1D2F40]">
          <div class="mb-[5px]">
            <img src="/images/services/Service-4-1.png" alt="Performance Enhancement" class="w-[17%] min-w-[68px] object-contain transition-transform duration-300 group-hover:scale-110" loading="lazy" />
          </div>
          <h4 class="font-heading text-[24px] font-medium leading-[1.2] text-[#1D2F40] mb-[5px]">Performance Enhancement</h4>
          <p class="font-body text-[17.6px] leading-[1.5] text-[#757575]">Our sportswear is designed to enhance performance, incorporating advanced fabric technologies and functional features that optimize athletic abilities.</p>
        </div>

        <!-- Sublimation Printing -->
        <div class="bg-[#F4F4F4] border border-[#A6587C] rounded-[10px] m-[1em] p-[3em] text-start group transition-all duration-300 hover:border-[#1D2F40]">
          <div class="mb-[5px]">
            <img src="/images/services/Service-5-1.png" alt="Sublimation Printing" class="w-[17%] min-w-[68px] object-contain transition-transform duration-300 group-hover:scale-110" loading="lazy" />
          </div>
          <h4 class="font-heading text-[24px] font-medium leading-[1.2] text-[#1D2F40] mb-[5px]">Sublimation Printing</h4>
          <p class="font-body text-[17.6px] leading-[1.5] text-[#757575]">Experience vibrant and long-lasting graphics on your sportswear through our sublimation printing technique, allowing for unlimited design possibilities.</p>
        </div>

        <!-- Quick Turnaround -->
        <div class="bg-[#F4F4F4] border border-[#A6587C] rounded-[10px] m-[1em] p-[3em] text-start group transition-all duration-300 hover:border-[#1D2F40]">
          <div class="mb-[5px]">
            <img src="/images/services/Service-1-1.png" alt="Quick Turnaround" class="w-[17%] min-w-[68px] object-contain transition-transform duration-300 group-hover:scale-110" loading="lazy" />
          </div>
          <h4 class="font-heading text-[24px] font-medium leading-[1.2] text-[#1D2F40] mb-[5px]">Quick Turnaround</h4>
          <p class="font-body text-[17.6px] leading-[1.5] text-[#757575]">With our efficient production processes and dedicated team, we offer fast turnaround times, ensuring your sportswear is delivered promptly, even for time-sensitive projects.</p>
        </div>
      </div>
    </div>
  </div>
</section>
