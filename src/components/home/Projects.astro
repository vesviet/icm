<section id="our-works" class="reveal py-[52.8px] bg-gray-50 border-t border-gray-200">
  <div class="max-w-[1340px] w-full mx-auto px-[10px]">
    <div class="text-center mb-16">
      <p class="font-nav text-[19.2px] font-semibold tracking-[2.5px] text-gold-500 uppercase mb-3">Portfolio</p>
      <h2 class="font-heading text-[52.8px] font-semibold leading-[1.2] text-navy-900 mb-4">OUR PROJECTS</h2>
      <p class="font-body text-[17.6px] leading-[1.5] text-gray-600 max-w-3xl mx-auto">Explore our trusted brand collaborations, where we join forces with industry leaders to deliver exceptional sportswear solutions that elevate their brand presence and drive success.</p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      <!-- 1. Hard Rock Cafe -->
      <div class="group relative overflow-hidden rounded-xl aspect-[3/4] bg-white shadow-md">
        <img src="/images/projects/Hard-Rock-Shop.png" alt="Hard Rock Cafe" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" />
        <div class="absolute inset-0 bg-gradient-to-t from-navy-900/90 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-end p-6">
          <h3 class="font-heading text-white text-[24px] font-medium leading-[1.2]">Hard Rock Cafe</h3>
        </div>
      </div>
      
      <!-- 2. JW Marriott -->
      <a href="/documents/JW-MARRIOTT-PRESENTATION-Final.pdf" target="_blank" class="group relative overflow-hidden rounded-xl aspect-[3/4] bg-white shadow-md block">
        <img src="/images/projects/Marriot.jpg" alt="JW Marriott" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" />
        <div class="absolute inset-0 bg-gradient-to-t from-navy-900/90 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-end p-6">
          <h3 class="font-heading text-white text-[24px] font-medium leading-[1.2] mb-2">JW Marriott</h3>
          <span class="text-gold-400 font-nav text-[14.4px] font-semibold tracking-[2px] uppercase flex items-center gap-1">VIEW MORE <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg></span>
        </div>
      </a>
      
