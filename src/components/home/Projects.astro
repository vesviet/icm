---
---
<section id="our-works" class="reveal relative py-[52.8px] bg-white overflow-hidden">
  <div class="absolute inset-0 opacity-20">
    <img src="/images/BG-2-1.png" alt="" class="w-full h-full object-cover" />
  </div>
  <div class="max-w-[1340px] w-full mx-auto px-[10px] relative z-10">
    <div class="text-center mb-16">
      <h2 class="font-nav text-[19.2px] font-semibold tracking-[2.5px] text-[#A6587C] uppercase mb-3">OUR PROJECT</h2>
      <h3 class="font-heading text-[52.8px] font-semibold leading-[1.2] text-[#1D2F40] mb-4">Trusted Brand Collaborations</h3>
      <p class="font-body text-[17.6px] leading-[1.5] text-[#757575] max-w-3xl mx-auto">Explore our trusted brand collaborations, where we join forces with industry leaders to deliver exceptional sportswear solutions that elevate their brand presence and drive success.</p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <!-- 1. Hard Rock Cafe -->
      <div class="bg-[#F2F2F2] border border-[#A6587C]">
        <img src="/images/projects/Hard-Rock-Shop.png" alt="Hard Rock Cafe" class="w-full aspect-square object-cover" />
        <div class="p-6 bg-[#1D2F40] min-h-[170px]">
          <h4 class="font-heading text-[#F4F4F4] text-[24px] font-medium leading-[1.2] mb-2">Hard Rock Cafe</h4>
          <p class="font-body text-[#D9D9D9] text-[17.6px] leading-[1.5]">Cultural yet classic promotional garment reflecting the iconic Hard Rock brand.</p>
        </div>
      </div>
      
      <!-- 2. JW Marriott -->
      <a href="/documents/JW-MARRIOTT-PRESENTATION-Final.pdf" target="_blank" class="bg-[#F2F2F2] border border-[#A6587C] block">
        <img src="/images/projects/Marriot.jpg" alt="JW Marriott" class="w-full aspect-square object-cover" />
        <div class="p-6 bg-[#1D2F40] min-h-[170px]">
          <h4 class="font-heading text-[#F4F4F4] text-[24px] font-medium leading-[1.2] mb-2">JW Marriot</h4>
          <p class="font-body text-[#D9D9D9] text-[17.6px] leading-[1.5] mb-4">Luxurious clothing with a perfect blend of comfort, design, and exclusive style.</p>
          <span class="inline-flex items-center gap-2 font-nav text-[14.4px] font-semibold tracking-[2px] uppercase text-[#A6587C]">VIEW MORE</span>
        </div>
      </a>
      
      <!-- 3. Mercedes Benz -->
      <a href="/documents/Mercedes-Collection.pdf" target="_blank" class="bg-[#F2F2F2] border border-[#A6587C] block">
        <img src="/images/projects/Mercerdes-Benz.png" alt="Mercedes Benz" class="w-full aspect-square object-cover" />
        <div class="p-6 bg-[#1D2F40] min-h-[170px]">
          <h4 class="font-heading text-[#F4F4F4] text-[24px] font-medium leading-[1.2] mb-2">Mercedes Benz</h4>
          <p class="font-body text-[#D9D9D9] text-[17.6px] leading-[1.5] mb-4">High-performance automotive clothing showcasing sophistication and quality.</p>
          <span class="inline-flex items-center gap-2 font-nav text-[14.4px] font-semibold tracking-[2px] uppercase text-[#A6587C]">VIEW MORE</span>
        </div>
      </a>

      <!-- 4. IronMan Triathlon -->
      <a href="/documents/IRONMAN-COLLECTION.pdf" target="_blank" class="bg-[#F2F2F2] border border-[#A6587C] block">
        <img src="/images/projects/IronMan.jpg" alt="IronMan Triathlon" class="w-full aspect-square object-cover" />
        <div class="p-6 bg-[#1D2F40] min-h-[170px]">
          <h4 class="font-heading text-[#F4F4F4] text-[24px] font-medium leading-[1.2] mb-2">IronMan Triathlon</h4>
          <p class="font-body text-[#D9D9D9] text-[17.6px] leading-[1.5] mb-4">Endurance-focused and high performance sportswear for conquering the challenges of Ironman.</p>
          <span class="inline-flex items-center gap-2 font-nav text-[14.4px] font-semibold tracking-[2px] uppercase text-[#A6587C]">VIEW MORE</span>
        </div>
      </a>

      <!-- 5. 2BU -->
      <a href="https://golf.icmfactorydirect.com" target="_blank" class="bg-[#F2F2F2] border border-[#A6587C] block">
        <img src="/images/projects/2bu-brand.jpg" alt="2BU" class="w-full aspect-square object-cover" />
        <div class="p-6 bg-[#1D2F40] min-h-[170px]">
          <h4 class="font-heading text-[#F4F4F4] text-[24px] font-medium leading-[1.2] mb-2">2BU</h4>
          <p class="font-body text-[#D9D9D9] text-[17.6px] leading-[1.5] mb-4">Fashion-forward, vibrant-color golf apparel that confidently empowers personal style both on and off the field.</p>
          <span class="inline-flex items-center gap-2 font-nav text-[14.4px] font-semibold tracking-[2px] uppercase text-[#A6587C]">VIEW MORE</span>
        </div>
      </a>

      <!-- 6. Super League -->
      <div class="bg-[#F2F2F2] border border-[#A6587C]">
        <img src="/images/projects/Super-League.png" alt="Super League" class="w-full aspect-square object-cover" />
        <div class="p-6 bg-[#1D2F40] min-h-[170px]">
          <h4 class="font-heading text-[#F4F4F4] text-[24px] font-medium leading-[1.2] mb-2">Super League</h4>
          <p class="font-body text-[#D9D9D9] text-[17.6px] leading-[1.5]">Excellence custom fit and design in sportswear, embodying passion and competitiveness of the elite triathlon.</p>
        </div>
      </div>

      <!-- 7. PHOTOtoFIT™ -->
      <a href="https://regna.ai/" target="_blank" class="bg-[#F2F2F2] border border-[#A6587C] block">
        <img src="/images/GOOGLE-ADS-SQUARE-1.jpg" alt="PHOTOtoFIT™" class="w-full aspect-square object-cover" />
        <div class="p-6 bg-[#1D2F40] min-h-[170px]">
          <h4 class="font-heading text-[#F4F4F4] text-[24px] font-medium leading-[1.2] mb-2">PHOTOtoFIT™</h4>
          <p class="font-body text-[#D9D9D9] text-[17.6px] leading-[1.5] mb-4">Leveraging AI to scan 100+ body measurements from only two photos for absolute precision.</p>
          <span class="inline-flex items-center gap-2 font-nav text-[14.4px] font-semibold tracking-[2px] uppercase text-[#A6587C]">VIEW MORE</span>
        </div>
      </a>

      <!-- 8. 2BU (duplicate per production site) -->
      <a href="https://golf.icmfactorydirect.com" target="_blank" class="bg-[#F2F2F2] border border-[#A6587C] block">
        <img src="/images/projects/2bu-brand.jpg" alt="2BU" class="w-full aspect-square object-cover" />
        <div class="p-6 bg-[#1D2F40] min-h-[170px]">
          <h4 class="font-heading text-[#F4F4F4] text-[24px] font-medium leading-[1.2] mb-2">2BU</h4>
          <p class="font-body text-[#D9D9D9] text-[17.6px] leading-[1.5] mb-4">Fashion-forward, vibrant-color golf apparel that confidently empowers personal style both on and off the field.</p>
          <span class="inline-flex items-center gap-2 font-nav text-[14.4px] font-semibold tracking-[2px] uppercase text-[#A6587C]">VIEW MORE</span>
        </div>
      </a>
    </div>
  </div>
</section>
